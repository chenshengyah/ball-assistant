{
  "name": "ball-assistant",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.8.0",
  "scripts": {
    "dev": "pnpm dev:backend",
    "dev:all": "turbo run dev --parallel",
    "dev:backend": "pnpm db:up && pnpm db:migrate && pnpm --filter @ball-assistant/api dev",
    "db:up": "docker compose -f infra/docker-compose.yml up -d",
    "db:migrate": "pnpm --dir apps/api exec prisma migrate deploy",
    "db:down": "docker compose -f infra/docker-compose.yml down",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test"
  },
  "devDependencies": {
    "@eslint/js": "^9.25.0",
    "eslint": "^9.25.0",
    "globals": "^15.15.0",
    "prettier": "^3.5.3",
    "turbo": "^2.5.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.30.1"
  }
}
