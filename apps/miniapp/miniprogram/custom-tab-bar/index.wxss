@import "../styles/theme.wxss";

.tab-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 120;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-around;
  box-sizing: border-box;
  border-radius: 24px 24px 0 0;
  border-top: 1px solid var(--iz-outline-strong);
  background: var(--iz-layer-tabbar);
  backdrop-filter: blur(18px);
  box-shadow: 0 -8px 28px var(--iz-shadow-medium);
}

.tab-bar__item {
  flex: 1;
  display: flex;
  align-items: stretch;
  flex-direction: row;
  justify-content: center;
  height: 100%;
}

.tab-bar__content {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 4px;
  width: 100%;
  height: 100%;
  min-width: 74px;
  padding: 8px 10px;
  color: var(--iz-text-secondary);
  box-sizing: border-box;
}

.tab-bar__content--active {
  min-width: 92px;
  border-radius: 16px;
  color: var(--iz-color-primary);
  background: var(--iz-surface-high);
}

.tab-bar__icon {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 20px;
}

.tab-bar__text {
  font-size: 11px;
  font-weight: 600;
  line-height: 1;
}

.tab-icon {
  position: relative;
  width: 20px;
  height: 20px;
}

.tab-icon__home-roof {
  position: absolute;
  top: 3px;
  left: 4px;
  width: 12px;
  height: 12px;
  border-top: 2px solid var(--iz-text-secondary);
  border-left: 2px solid var(--iz-text-secondary);
  transform: rotate(45deg);
  box-sizing: border-box;
}

.tab-icon__home-body {
  position: absolute;
  left: 5px;
  bottom: 2px;
  width: 10px;
  height: 8px;
  border: 2px solid var(--iz-text-secondary);
  border-top: none;
  border-radius: 0 0 3px 3px;
  box-sizing: border-box;
}

.tab-icon__calendar-body {
  position: absolute;
  left: 2px;
  top: 4px;
  width: 16px;
  height: 14px;
  border: 2px solid var(--iz-text-secondary);
  border-radius: 4px;
  box-sizing: border-box;
}

.tab-icon__calendar-bar {
  position: absolute;
  left: 5px;
  top: 7px;
  width: 10px;
  height: 2px;
  border-radius: 999px;
  background: var(--iz-text-secondary);
}

.tab-icon__calendar-ring {
  position: absolute;
  top: 1px;
  width: 3px;
  height: 5px;
  border-radius: 999px;
  background: var(--iz-text-secondary);
}

.tab-icon__calendar-ring--left {
  left: 5px;
}

.tab-icon__calendar-ring--right {
  right: 5px;
}

.tab-icon__profile-head {
  position: absolute;
  left: 6px;
  top: 2px;
  width: 8px;
  height: 8px;
  border: 2px solid var(--iz-text-secondary);
  border-radius: 50%;
  box-sizing: border-box;
}

.tab-icon__profile-shoulder {
  position: absolute;
  left: 3px;
  bottom: 2px;
  width: 14px;
  height: 7px;
  border: 2px solid var(--iz-text-secondary);
  border-top: none;
  border-radius: 0 0 8px 8px;
  box-sizing: border-box;
}

.tab-bar__content--active .tab-icon__home-roof {
  border-top-color: var(--iz-color-primary);
  border-left-color: var(--iz-color-primary);
}

.tab-bar__content--active .tab-icon__home-body {
  border-color: var(--iz-color-primary);
  border-top: none;
}

.tab-bar__content--active .tab-icon__calendar-body {
  border-color: var(--iz-color-primary);
}

.tab-bar__content--active .tab-icon__calendar-bar,
.tab-bar__content--active .tab-icon__calendar-ring {
  background: var(--iz-color-primary);
}

.tab-bar__content--active .tab-icon__profile-head,
.tab-bar__content--active .tab-icon__profile-shoulder {
  border-color: var(--iz-color-primary);
}
