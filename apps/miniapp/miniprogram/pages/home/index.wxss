@import "../../styles/theme.wxss";

page {
  background: var(--iz-surface);
}

.home-page {
  min-height: 100vh;
  color: var(--iz-text-primary);
  background: var(--iz-surface);
}

.home-topbar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 50;
  display: flex;
  flex-direction: row;
  align-items: center;
  padding-left: 16px;
  padding-right: 16px;
  box-sizing: border-box;
  border-bottom: 1px solid var(--iz-outline-soft);
  background: var(--iz-layer-topbar);
  backdrop-filter: blur(18px);
}

.home-topbar__actions {
  flex: 1;
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 12px;
}

.home-topbar__title {
  position: absolute;
  left: 50%;
  transform: translateX(-50%);
  font-size: 18px;
  font-weight: 700;
  letter-spacing: -0.02em;
}

.home-topbar__capsule-placeholder {
  display: flex;
  justify-content: flex-end;
  flex-shrink: 0;
}

.topbar-icon-button {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 24px;
  height: 24px;
  padding: 0;
  transition: opacity 0.2s ease;
}

.topbar-icon-button--hover {
  opacity: 0.8;
}

.icon-grid {
  display: grid;
  grid-template-columns: repeat(2, 7px);
  gap: 4px;
}

.icon-grid__dot {
  width: 7px;
  height: 7px;
  border-radius: 2px;
  background: var(--iz-color-primary);
}

.icon-search {
  position: relative;
  width: 18px;
  height: 18px;
}

.icon-search__circle {
  width: 12px;
  height: 12px;
  border: 2px solid var(--iz-text-secondary);
  border-radius: 50%;
  box-sizing: border-box;
}

.icon-search__handle {
  position: absolute;
  right: 0;
  bottom: 1px;
  width: 8px;
  height: 2px;
  border-radius: 999px;
  background: var(--iz-text-secondary);
  transform: rotate(40deg);
  transform-origin: center;
}

.home-content {
  min-height: 100vh;
  box-sizing: border-box;
}

.home-hero__title {
  font-size: 56px;
  line-height: 1.08;
  font-weight: 700;
  letter-spacing: -0.04em;
}

.home-hero__subtitle {
  margin-top: 6px;
  color: var(--iz-text-secondary);
  font-size: 14px;
  line-height: 1.5;
  font-weight: 500;
}

.home-quick-actions {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12px;
  margin-top: 18px;
}

.home-quick-action {
  min-height: 120px;
  padding: 18px;
  border-radius: 24px;
  background: var(--iz-surface-lowest);
  border: 1px solid var(--iz-outline);
  box-shadow: 0 10px 24px var(--iz-shadow-soft);
  box-sizing: border-box;
}

.home-quick-action--primary {
  background: linear-gradient(135deg, var(--iz-color-primary), var(--iz-color-primary-strong));
  border-color: transparent;
}

.home-quick-action__eyebrow {
  font-size: 10px;
  font-weight: 800;
  letter-spacing: 0.14em;
  color: var(--iz-color-primary);
}

.home-quick-action--primary .home-quick-action__eyebrow,
.home-quick-action--primary .home-quick-action__title,
.home-quick-action--primary .home-quick-action__meta {
  color: var(--iz-surface-on-primary);
}

.home-quick-action__title {
  margin-top: 12px;
  font-size: 17px;
  line-height: 1.2;
  font-weight: 700;
  color: var(--iz-text-primary);
}

.home-quick-action__meta {
  margin-top: 8px;
  font-size: 12px;
  line-height: 1.6;
  color: var(--iz-text-secondary);
}

.home-search-block {
  margin-top: 16px;
}

.home-search {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 8px;
}

.home-search__field {
  flex: 1;
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 10px;
  height: 36px;
  padding: 0 16px;
  border-radius: 999px;
  background: var(--iz-layer-search);
  border: 1px solid var(--iz-outline-focus);
  box-sizing: border-box;
}

.icon-search--field {
  width: 16px;
  height: 16px;
}

.icon-search--field .icon-search__circle,
.icon-search--field .icon-search__handle {
  background-color: var(--iz-text-secondary);
  border-color: var(--iz-text-secondary);
}

.home-search__input {
  flex: 1;
  min-width: 0;
  height: 100%;
  color: var(--iz-text-primary);
  font-size: 12px;
  font-weight: 500;
}

.home-search__placeholder {
  color: var(--iz-text-secondary);
  font-size: 12px;
  font-weight: 500;
}

.home-search__filter {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 36px;
  height: 36px;
  padding: 0;
  border-radius: 999px;
  background: var(--iz-surface-high);
  box-sizing: border-box;
  transition: opacity 0.2s ease;
}

.home-search__filter--hover {
  opacity: 0.9;
}

.icon-tune {
  position: relative;
  width: 18px;
  height: 18px;
}

.icon-tune__line {
  position: absolute;
  left: 0;
  width: 18px;
  height: 2px;
  border-radius: 999px;
  background: var(--iz-color-primary);
}

.icon-tune__line--one {
  top: 3px;
}

.icon-tune__line--two {
  top: 8px;
}

.icon-tune__line--three {
  top: 13px;
}

.icon-tune__knob {
  position: absolute;
  width: 5px;
  height: 5px;
  border-radius: 50%;
  background: var(--iz-color-primary);
}

.icon-tune__knob--one {
  top: 1px;
  left: 9px;
}

.icon-tune__knob--two {
  top: 6px;
  left: 3px;
}

.icon-tune__knob--three {
  top: 11px;
  left: 12px;
}

.category-strip {
  display: flex;
  flex-direction: row;
  white-space: nowrap;
}

.category-strip__inner {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 8px;
  padding-right: 24px;
}

.category-chip {
  display: flex;
  flex-shrink: 0;
  align-items: center;
  justify-content: center;
  height: 32px;
  padding: 0 20px;
  border-radius: 999px;
  color: var(--iz-text-secondary);
  font-size: 12px;
  font-weight: 700;
  line-height: 1;
  background: var(--iz-surface-low);
  box-sizing: border-box;
  transition: opacity 0.2s ease;
}

.category-chip--active {
  color: var(--iz-surface-on-primary);
  background: var(--iz-color-primary);
  box-shadow: 0 4px 10px var(--iz-shadow-primary-soft);
}

.category-chip--hover {
  opacity: 0.88;
}

.activity-list {
  display: flex;
  flex-direction: column;
  gap: 16px;
  margin-top: 16px;
}

.activity-card {
  overflow: hidden;
  border-radius: 24px;
  background: var(--iz-surface-lowest);
  border: 1px solid var(--iz-outline);
  box-shadow: 0 6px 20px var(--iz-shadow-soft);
}

.activity-card__cover {
  position: relative;
  height: 128px;
  overflow: hidden;
}

.activity-card__image {
  width: 100%;
  height: 100%;
}

.activity-card__price-badge {
  position: absolute;
  top: 8px;
  right: 8px;
  min-width: 56px;
  height: 24px;
  padding: 0 10px;
  border-radius: 999px;
  font-size: 10px;
  font-weight: 800;
  line-height: 24px;
  text-align: center;
  letter-spacing: 0.06em;
  box-sizing: border-box;
  background: var(--iz-layer-glass);
  backdrop-filter: blur(8px);
}

.activity-card__price-badge--primary {
  color: var(--iz-color-primary);
}

.activity-card__price-badge--success {
  color: var(--iz-color-success);
}

.activity-card__body {
  display: flex;
  flex-direction: column;
  gap: 12px;
  padding: 16px;
}

.activity-card__eyebrow {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  font-size: 9px;
  font-weight: 700;
  letter-spacing: 0.14em;
  text-transform: uppercase;
}

.activity-card__eyebrow--primary {
  color: var(--iz-color-primary);
}

.activity-card__eyebrow--tertiary {
  color: var(--iz-color-tertiary);
}

.activity-card__eyebrow-icon {
  width: 6px;
  height: 6px;
  border-radius: 50%;
  background: var(--iz-color-primary);
}

.activity-card__eyebrow--tertiary .activity-card__eyebrow-icon {
  background: var(--iz-color-tertiary);
}

.activity-card__title {
  margin-top: -4px;
  font-size: 18px;
  line-height: 1.3;
  font-weight: 700;
  letter-spacing: -0.03em;
}

.activity-card__meta {
  display: flex;
  flex-direction: column;
  gap: 6px;
  margin-top: -2px;
}

.activity-card__meta-item {
  display: flex;
  align-items: center;
  gap: 8px;
  color: var(--iz-text-secondary);
}

.activity-card__meta-text {
  font-size: 12px;
  font-weight: 600;
}

.meta-icon {
  width: 14px;
  height: 14px;
  border-radius: 50%;
  opacity: 0.7;
  background: var(--iz-meta-icon);
}

.meta-icon--schedule {
  background: var(--iz-meta-icon-strong);
}

.activity-card__footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-top: 12px;
  border-top: 1px solid var(--iz-outline-soft);
}

.activity-card__joined {
  display: flex;
  align-items: center;
  gap: 8px;
  min-width: 0;
}

.activity-card__avatars {
  display: flex;
  align-items: center;
}

.activity-card__avatar {
  width: 20px;
  height: 20px;
  margin-left: -6px;
  border: 1px solid var(--iz-surface-lowest);
  border-radius: 50%;
  box-sizing: border-box;
}

.activity-card__avatar:first-child {
  margin-left: 0;
}

.activity-card__joined-text {
  color: var(--iz-text-secondary);
  font-size: 10px;
  font-weight: 700;
}

.activity-card__cta {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 28px;
  padding: 0 16px;
  border-radius: 999px;
  color: var(--iz-surface-on-primary);
  font-size: 10px;
  font-weight: 800;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  background: var(--iz-color-primary);
  box-sizing: border-box;
  transition: opacity 0.2s ease;
}

.activity-card__cta--hover {
  opacity: 0.9;
}

.home-empty {
  margin-top: 16px;
  padding: 40px 24px;
  border-radius: 24px;
  background: var(--iz-layer-empty);
  text-align: center;
}

.home-empty__number {
  color: var(--iz-surface-highest);
  font-size: 48px;
  line-height: 1;
  font-weight: 800;
}

.home-empty__title {
  margin-top: 16px;
  font-size: 16px;
  font-weight: 700;
}

.home-empty__subtitle {
  margin-top: 8px;
  color: var(--iz-text-secondary);
  font-size: 12px;
  line-height: 1.6;
}

.home-stats {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8px;
  padding: 40px 0;
}

.home-stats__number {
  color: var(--iz-surface-high);
  font-size: 48px;
  line-height: 1;
  font-weight: 800;
}

.home-stats__label {
  color: var(--iz-text-secondary);
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 0.2em;
}

.home-fab {
  position: fixed;
  z-index: 50;
  display: flex;
  align-items: center;
  gap: 8px;
  height: 48px;
  padding: 0 20px;
  border-radius: 999px;
  color: var(--iz-surface-on-primary);
  font-size: 14px;
  font-weight: 700;
  background: var(--iz-color-primary);
  box-shadow: 0 12px 24px var(--iz-shadow-primary-strong);
  box-sizing: border-box;
  transition: opacity 0.2s ease;
}

.home-fab--hover {
  opacity: 0.9;
}

.home-fab__plus {
  font-size: 18px;
  line-height: 1;
}
