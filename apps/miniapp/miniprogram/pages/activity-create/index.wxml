<app-nav title="创建活动" fallbackUrl="/pages/home/index"></app-nav>

<view class="create-page" style="{{pageTopStyle}}">
  <view class="create-page__hero">
    <view class="create-page__eyebrow"><text>{{currentUserName}}</text></view>
    <view class="create-page__title"><text>{{pageTitle}}</text></view>
    <view class="create-page__subtitle"><text>{{pageCaption}}</text></view>
  </view>

  <view
    wx:if="{{republishNotice}}"
    class="notice-card"
  ><text>{{republishNotice}}</text></view>

  <view class="section-card">
    <view class="section-title"><text>选择发布角色</text></view>

    <view class="form-section">
      <view class="form-label"><text>发布角色</text></view>
      <view class="owner-card-list">
        <view
          wx:for="{{ownerCardItems}}"
          wx:key="key"
          wx:for-item="ownerCard"
          class="owner-card {{selectedRoleType === ownerCard.key ? 'owner-card--active' : ''}}"
          data-field="{{ownerCard.key}}"
          bindtap="handleOwnerSelect"
        >
          <view class="owner-card__top">
            <view class="owner-card__tag"><text>{{ownerCard.tag}}</text></view>
            <view
              wx:if="{{selectedRoleType === ownerCard.key}}"
              class="owner-card__selected"
            ><text>当前角色</text></view>
          </view>
          <view class="owner-card__title"><text>{{ownerCard.title}}</text></view>
          <view class="owner-card__meta"><text>{{ownerCard.meta}}</text></view>
          <view class="owner-card__status"><text>{{ownerCard.statusText}}</text></view>
        </view>
      </view>
      <view class="form-help"><text>{{ownerContactHint}}</text></view>
    </view>
  </view>

  <block wx:if="{{showRoleContent}}">
  <view class="section-card">
    <view class="section-title"><text>发布信息</text></view>

    <view class="form-section">
      <view class="form-label"><text>活动封面</text></view>
      <view class="cover-uploader" bindtap="handleUploadCover">
        <image
          wx:if="{{createForm.coverUrl}}"
          class="cover-uploader__image"
          src="{{createForm.coverUrl}}"
          mode="aspectFill"
        />
        <view wx:else class="cover-uploader__placeholder">
          <text>点击上传活动封面</text>
        </view>
      </view>
      <view class="form-help"><text>封面为选填，发布后可用于活动卡片与详情头图展示。</text></view>
    </view>

    <view class="form-section">
      <view class="form-label"><text>活动名称</text></view>
      <input
        class="text-field"
        value="{{createForm.title}}"
        placeholder="例如：周三晚场双打局"
        data-field="title"
        bindinput="handleCreateInput"
      />
    </view>

    <view class="form-grid">
      <view class="form-grid__item">
        <view class="form-label"><text>收费方式</text></view>
        <picker
          mode="selector"
          range="{{chargeModeLabels}}"
          value="{{selectedChargeModeIndex}}"
          bindchange="handleChargeModeChange"
        >
          <view class="picker-field"><text>{{chargeModeLabels[selectedChargeModeIndex]}}</text></view>
        </picker>
      </view>

      <view class="form-grid__item">
        <view class="form-label"><text>收费金额（元）</text></view>
        <input
          class="text-field"
          type="digit"
          value="{{createForm.chargeAmountYuan}}"
          placeholder="0"
          data-field="chargeAmountYuan"
          bindinput="handleCreateInput"
        />
      </view>
    </view>

    <view class="form-section">
      <view class="form-label"><text>收费说明</text></view>
      <input
        class="text-field"
        value="{{createForm.chargeDesc}}"
        placeholder="例如：含场地和球"
        data-field="chargeDesc"
        bindinput="handleCreateInput"
      />
    </view>
  </view>

  <view class="section-card">
    <view class="section-title"><text>时间信息</text></view>

    <view class="form-grid">
      <view class="form-grid__item">
        <view class="form-label"><text>活动日期</text></view>
        <picker
          mode="date"
          value="{{createForm.activityDate}}"
          bindchange="handleCreateInput"
          data-field="activityDate"
        >
          <view class="picker-field"><text>{{createForm.activityDate}}</text></view>
        </picker>
      </view>

      <view class="form-grid__item">
        <view class="form-label"><text>开始时间</text></view>
        <picker
          mode="time"
          value="{{createForm.startTime}}"
          bindchange="handleCreateInput"
          data-field="startTime"
        >
          <view class="picker-field"><text>{{createForm.startTime}}</text></view>
        </picker>
      </view>
    </view>

    <view class="form-grid">
      <view class="form-grid__item">
        <view class="form-label"><text>结束时间</text></view>
        <picker
          mode="time"
          value="{{createForm.endTime}}"
          bindchange="handleCreateInput"
          data-field="endTime"
        >
          <view class="picker-field"><text>{{createForm.endTime}}</text></view>
        </picker>
      </view>

      <view class="form-grid__item">
        <view class="form-label"><text>停止取消规则</text></view>
        <picker
          mode="selector"
          range="{{cancelCutoffLabels}}"
          value="{{selectedCancelCutoffIndex}}"
          bindchange="handleCancelCutoffChange"
        >
          <view class="picker-field"><text>{{cancelCutoffLabels[selectedCancelCutoffIndex]}}</text></view>
        </picker>
      </view>
    </view>
  </view>

  <view class="section-card">
    <view class="section-header">
      <view class="section-title"><text>报名与场馆</text></view>
    </view>

    <view class="form-section">
      <view class="form-label"><text>报名模式</text></view>
      <view class="mode-card-list">
        <view
          wx:for="{{signupModeLabels}}"
          wx:key="index"
          wx:for-item="signupModeLabel"
          class="mode-card {{selectedSignupModeIndex === index ? 'mode-card--active' : ''}}"
          data-signup-mode-index="{{index}}"
          bindtap="handleSignupModeSelect"
        >
          <view class="mode-card__title"><text>{{signupModeLabel}}</text></view>
          <view class="mode-card__meta">
            <text>{{index === 0 ? '先配置场地，用户报名时自主选择' : '用户先报名，后续由主办方线下统一分配'}}</text>
          </view>
        </view>
      </view>
    </view>

    <view class="form-section">
      <view class="form-label"><text>球馆定位</text></view>
      <view class="location-card">
        <view class="location-card__row">
          <view class="location-card__label"><text>定位</text></view>
          <view class="section-link" bindtap="handleChooseVenueLocation"><text>搜索球馆</text></view>
        </view>
        <view class="location-card__row">
          <view class="location-card__label"><text>球馆</text></view>
          <view class="location-card__value"><text>{{createForm.venueName || '未填写'}}</text></view>
        </view>
        <view class="location-card__row">
          <view class="location-card__label"><text>地址</text></view>
          <view class="location-card__value"><text>{{createForm.venueAddress || '未填写'}}</text></view>
        </view>
      </view>
      <view class="form-help"><text>可以先用地图搜索定位，再按实际活动名称微调。</text></view>
    </view>

    <view class="form-section">
      <view class="form-label"><text>球馆名称</text></view>
      <input
        class="text-field"
        value="{{createForm.venueName}}"
        placeholder="例如：浦东金桥羽毛球馆"
        data-field="venueName"
        bindinput="handleCreateInput"
      />
    </view>

    <view class="form-section">
      <view class="form-label"><text>球馆地址</text></view>
      <input
        class="text-field"
        value="{{createForm.venueAddress}}"
        placeholder="例如：金桥路 588 号 B1"
        data-field="venueAddress"
        bindinput="handleCreateInput"
      />
    </view>

    <view
      wx:if="{{createForm.signupMode === 'GENERAL'}}"
      class="form-section"
    >
      <view class="form-label"><text>活动总人数</text></view>
      <input
        class="text-field"
        type="number"
        value="{{createForm.totalCapacity}}"
        placeholder="例如：36"
        data-field="totalCapacity"
        bindinput="handleCreateInput"
      />
      <view class="form-help"><text>用户先报名，组织者后续线下统一分配，系统内不落到具体场地。</text></view>
    </view>

    <view
      wx:if="{{createForm.signupMode === 'USER_SELECT_COURT'}}"
      class="form-section"
    >
      <view class="form-label"><text>报名场地</text></view>
      <view class="form-help"><text>只配置本次活动开放报名的场地，不会沉淀为独立场地资料。</text></view>

      <view class="court-list">
        <view
          wx:for="{{availableCourts}}"
          wx:key="id"
          wx:for-item="court"
          class="court-card court-card--active"
        >
          <view class="court-card__top">
            <view class="court-card__name"><text>{{court.label || '未命名场地'}}</text></view>
            <view
              class="court-card__toggle"
              data-court-index="{{index}}"
              bindtap="handleRemoveCourt"
            ><text>删除</text></view>
          </view>

          <view>
            <view class="form-section">
              <view class="form-label"><text>场地名称</text></view>
              <input
                class="text-field"
                value="{{court.label}}"
                placeholder="例如：1 号场"
                data-court-index="{{index}}"
                data-field="label"
                bindinput="handleCourtInput"
              />
            </view>
            <view class="form-section">
              <view class="form-label"><text>人数上限</text></view>
              <input
                class="text-field"
                type="number"
                value="{{court.capacity}}"
                data-court-index="{{index}}"
                data-field="capacity"
                bindinput="handleCourtInput"
              />
            </view>
          </view>
        </view>
      </view>
      <view class="empty-field__action" bindtap="handleAddCourt"><text>新增场地</text></view>
    </view>
  </view>

  <view class="section-card">
    <view class="section-header">
      <view class="section-title"><text>活动图文详情</text></view>
      <view class="editor-toolbar">
        <view
          class="section-link"
          bindtap="handleAddParagraphBlock"
        ><text>新增文字</text></view>
        <view
          class="section-link"
          bindtap="handleAddImageBlock"
        ><text>插入图片</text></view>
      </view>
    </view>

    <view class="form-help"><text>支持文字段落与图片混排，可为空；当前版本不支持视频、外链、表格和复杂排版。</text></view>

    <view class="description-editor">
      <view
        wx:for="{{descriptionBlocks}}"
        wx:key="id"
        wx:for-item="block"
        class="description-block"
      >
        <view class="description-block__header">
          <view class="description-block__label"><text>{{block.type === 'paragraph' ? '文字段落' : '图片内容'}}</text></view>
          <view class="description-block__actions">
            <view
              class="block-action {{index === 0 ? 'block-action--disabled' : ''}}"
              data-block-index="{{index}}"
              data-delta="-1"
              bindtap="handleMoveDescriptionBlock"
            ><text>上移</text></view>
            <view
              class="block-action {{index === descriptionBlocks.length - 1 ? 'block-action--disabled' : ''}}"
              data-block-index="{{index}}"
              data-delta="1"
              bindtap="handleMoveDescriptionBlock"
            ><text>下移</text></view>
            <view
              class="block-action block-action--danger"
              data-block-index="{{index}}"
              bindtap="handleDeleteDescriptionBlock"
            ><text>删除</text></view>
          </view>
        </view>

        <textarea
          wx:if="{{block.type === 'paragraph'}}"
          class="textarea-field textarea-field--block"
          value="{{block.text}}"
          placeholder="填写玩法、水平要求、报名说明等"
          data-block-index="{{index}}"
          bindinput="handleDescriptionBlockInput"
        ></textarea>

        <view
          wx:if="{{block.type === 'image'}}"
          class="image-block"
        >
          <image
            class="image-block__preview"
            src="{{block.src}}"
            mode="aspectFill"
          />
          <view class="image-block__footer">
            <view class="form-help"><text>图片将按当前顺序展示在活动详情中。</text></view>
            <view
              class="section-link"
              data-block-index="{{index}}"
              bindtap="handleReplaceImageBlock"
            ><text>更换图片</text></view>
          </view>
        </view>
      </view>
    </view>
    </view>

    <view class="page-actions">
      <view
        class="action-button action-button--secondary"
        bindtap="handleBack"
      ><text>返回</text></view>
      <view
        class="action-button action-button--primary"
        bindtap="handleSubmitCreate"
      ><text>发布活动</text></view>
    </view>
  </block>
</view>

<view
  wx:if="{{showProfileSheet}}"
  class="sheet-mask"
  bindtap="handleCloseProfileSheet"
></view>
<view
  wx:if="{{showProfileSheet}}"
  class="venue-sheet"
  catchtap="handleVenueSheetTap"
>
  <view class="venue-sheet__handle">
    <view class="venue-sheet__handle-bar"></view>
  </view>
  <view class="venue-sheet__header">
    <view class="venue-sheet__title"><text>完善个人资料</text></view>
    <view class="venue-sheet__subtitle"><text>先补齐基础资料和联系手机号，再进入活动创建配置。</text></view>
  </view>
  <scroll-view class="venue-sheet__body" scroll-y="true" show-scrollbar="{{false}}">
    <view class="venue-sheet__section">
      <profile-form
        value="{{profileSheetForm}}"
        require-base="{{true}}"
        require-phone="{{true}}"
        bind:change="handleProfileFormChange"
      />
    </view>
  </scroll-view>
  <view class="venue-sheet__footer">
    <view class="action-button action-button--secondary" bindtap="handleCloseProfileSheet"><text>取消</text></view>
    <view class="action-button action-button--primary" bindtap="handleSubmitProfileSheet"><text>保存并继续</text></view>
  </view>
</view>

<view
  wx:if="{{showClubSheet}}"
  class="sheet-mask"
  bindtap="handleCloseClubSheet"
></view>
<view
  wx:if="{{showClubSheet}}"
  class="venue-sheet"
  catchtap="handleVenueSheetTap"
>
  <view class="venue-sheet__handle">
    <view class="venue-sheet__handle-bar"></view>
  </view>
  <view class="venue-sheet__header">
    <view class="venue-sheet__title"><text>俱乐部资料</text></view>
    <view class="venue-sheet__subtitle"><text>先补齐创建人资料，再创建可发布的俱乐部主体。</text></view>
  </view>
  <scroll-view class="venue-sheet__body" scroll-y="true" show-scrollbar="{{false}}">
    <view class="venue-sheet__section">
      <view class="form-label"><text>创建人资料</text></view>
      <view class="form-help"><text>俱乐部联系人将使用创建人的昵称和手机号。</text></view>
      <profile-form
        value="{{profileSheetForm}}"
        require-base="{{true}}"
        require-phone="{{true}}"
        compact-when-complete="{{true}}"
        bind:change="handleProfileFormChange"
      />
    </view>
    <view wx:if="{{clubOwnerLabels.length > 0}}" class="venue-sheet__section">
      <view class="form-label"><text>已有俱乐部</text></view>
      <picker range="{{clubOwnerLabels}}" value="{{selectedClubOwnerIndex}}" bindchange="handleClubOwnerChange">
        <view class="picker-field"><text>{{clubOwnerLabels[selectedClubOwnerIndex] || '新建俱乐部'}}</text></view>
      </picker>
    </view>
    <view class="venue-sheet__section">
      <view class="form-label"><text>俱乐部封面</text></view>
      <view class="cover-uploader" bindtap="handleUploadClubCover">
        <image wx:if="{{clubSheetForm.coverUrl}}" class="cover-uploader__image" src="{{clubSheetForm.coverUrl}}" mode="aspectFill" />
        <view wx:else class="cover-uploader__placeholder"><text>点击上传俱乐部封面</text></view>
      </view>
    </view>
    <view class="venue-sheet__section">
      <view class="form-label"><text>俱乐部 Logo</text></view>
      <view class="cover-uploader cover-uploader--logo" bindtap="handleUploadClubLogo">
        <image wx:if="{{clubSheetForm.logoUrl}}" class="cover-uploader__image" src="{{clubSheetForm.logoUrl}}" mode="aspectFill" />
        <view wx:else class="cover-uploader__placeholder"><text>点击上传 Logo</text></view>
      </view>
    </view>
    <view class="venue-sheet__section">
      <view class="form-label"><text>俱乐部名称</text></view>
      <input class="text-field" value="{{clubSheetForm.name}}" data-field="name" bindinput="handleClubInput" />
    </view>
    <view class="venue-sheet__section">
      <view class="form-label"><text>俱乐部简介</text></view>
      <textarea class="textarea-field textarea-field--block" value="{{clubSheetForm.description}}" data-field="description" bindinput="handleClubInput"></textarea>
    </view>
  </scroll-view>
  <view class="venue-sheet__footer">
    <view class="action-button action-button--secondary" bindtap="handleCloseClubSheet"><text>取消</text></view>
    <view class="action-button action-button--primary" bindtap="handleSubmitClubSheet"><text>保存并继续</text></view>
  </view>
</view>
