<app-nav title="创建活动" fallbackUrl="/pages/activity/index"></app-nav>

<view class="create-page" style="{{pageTopStyle}}">
  <view class="create-page__hero">
    <view class="create-page__eyebrow"><text>{{currentUserName}}</text></view>
    <view class="create-page__title"><text>{{pageTitle}}</text></view>
    <view class="create-page__subtitle"><text>{{pageCaption}}</text></view>
  </view>

  <view
    wx:if="{{republishNotice}}"
    class="notice-card"
  ><text>{{republishNotice}}</text></view>

    <view class="section-card">
      <view class="section-title"><text>发布信息</text></view>

    <view class="form-section">
      <view class="form-label"><text>发布身份</text></view>
      <view class="owner-card-list">
        <view
          wx:for="{{ownerCardItems}}"
          wx:key="index"
          wx:for-item="ownerCard"
          class="owner-card {{selectedOwnerIndex === index ? 'owner-card--active' : ''}}"
          data-owner-index="{{index}}"
          bindtap="handleOwnerSelect"
        >
          <view class="owner-card__top">
            <view class="owner-card__tag"><text>{{ownerCard.tag}}</text></view>
            <view
              wx:if="{{selectedOwnerIndex === index}}"
              class="owner-card__selected"
            ><text>当前发布身份</text></view>
          </view>
          <view class="owner-card__title"><text>{{ownerCard.title}}</text></view>
          <view class="owner-card__meta"><text>{{ownerCard.meta}}</text></view>
        </view>
      </view>
      <view class="form-help"><text>{{ownerContactHint}}</text></view>
    </view>

    <view class="form-section">
      <view class="form-label"><text>活动名称</text></view>
      <input
        class="text-field"
        value="{{createForm.title}}"
        placeholder="例如：周三晚场双打局"
        data-field="title"
        bindinput="handleCreateInput"
      />
    </view>

    <view class="form-section">
      <view class="form-label"><text>发起人微信号</text></view>
      <input
        class="text-field"
        value="{{createForm.organizerWechat}}"
        placeholder="例如：badminton_ava"
        data-field="organizerWechat"
        bindinput="handleCreateInput"
      />
      <view class="form-help"><text>会展示在活动详情页，供报名人联系你。</text></view>
    </view>

    <view class="form-grid">
      <view class="form-grid__item">
        <view class="form-label"><text>收费方式</text></view>
        <picker
          mode="selector"
          range="{{chargeModeLabels}}"
          value="{{selectedChargeModeIndex}}"
          bindchange="handleChargeModeChange"
        >
          <view class="picker-field"><text>{{chargeModeLabels[selectedChargeModeIndex]}}</text></view>
        </picker>
      </view>

      <view class="form-grid__item">
        <view class="form-label"><text>收费金额（元）</text></view>
        <input
          class="text-field"
          type="digit"
          value="{{createForm.chargeAmountYuan}}"
          placeholder="0"
          data-field="chargeAmountYuan"
          bindinput="handleCreateInput"
        />
      </view>
    </view>

    <view class="form-section">
      <view class="form-label"><text>收费说明</text></view>
      <input
        class="text-field"
        value="{{createForm.chargeDesc}}"
        placeholder="例如：含场地和球"
        data-field="chargeDesc"
        bindinput="handleCreateInput"
      />
    </view>
  </view>

  <view class="section-card">
    <view class="section-title"><text>时间信息</text></view>

    <view class="form-grid">
      <view class="form-grid__item">
        <view class="form-label"><text>活动日期</text></view>
        <picker
          mode="date"
          value="{{createForm.activityDate}}"
          bindchange="handleCreateInput"
          data-field="activityDate"
        >
          <view class="picker-field"><text>{{createForm.activityDate}}</text></view>
        </picker>
      </view>

      <view class="form-grid__item">
        <view class="form-label"><text>开始时间</text></view>
        <picker
          mode="time"
          value="{{createForm.startTime}}"
          bindchange="handleCreateInput"
          data-field="startTime"
        >
          <view class="picker-field"><text>{{createForm.startTime}}</text></view>
        </picker>
      </view>
    </view>

    <view class="form-grid">
      <view class="form-grid__item">
        <view class="form-label"><text>结束时间</text></view>
        <picker
          mode="time"
          value="{{createForm.endTime}}"
          bindchange="handleCreateInput"
          data-field="endTime"
        >
          <view class="picker-field"><text>{{createForm.endTime}}</text></view>
        </picker>
      </view>

      <view class="form-grid__item">
        <view class="form-label"><text>停止取消规则</text></view>
        <picker
          mode="selector"
          range="{{cancelCutoffLabels}}"
          value="{{selectedCancelCutoffIndex}}"
          bindchange="handleCancelCutoffChange"
        >
          <view class="picker-field"><text>{{cancelCutoffLabels[selectedCancelCutoffIndex]}}</text></view>
        </picker>
      </view>
    </view>
  </view>

  <view class="section-card">
    <view class="section-header">
      <view class="section-title"><text>报名与场馆</text></view>
      <view
        class="section-link"
        bindtap="handleOpenVenueManager"
      ><text>管理场馆与场地</text></view>
    </view>

    <view class="form-section">
      <view class="form-label"><text>报名模式</text></view>
      <view class="mode-card-list">
        <view
          wx:for="{{signupModeLabels}}"
          wx:key="index"
          wx:for-item="signupModeLabel"
          class="mode-card {{selectedSignupModeIndex === index ? 'mode-card--active' : ''}}"
          data-signup-mode-index="{{index}}"
          bindtap="handleSignupModeSelect"
        >
          <view class="mode-card__title"><text>{{signupModeLabel}}</text></view>
          <view class="mode-card__meta">
            <text>{{index === 0 ? '先配置场地，用户报名时自主选择' : '用户先报名，后续由主办方线下统一分配'}}</text>
          </view>
        </view>
      </view>
    </view>

    <view class="form-section">
      <view class="form-label"><text>选择场馆</text></view>
      <picker
        mode="selector"
        range="{{venueLabels}}"
        value="{{selectedVenueIndex}}"
        bindchange="handleVenueChange"
      >
        <view class="picker-field"><text>{{venueLabels[selectedVenueIndex]}}</text></view>
      </picker>
    </view>

    <view
      wx:if="{{createForm.signupMode === 'GENERAL'}}"
      class="form-section"
    >
      <view class="form-label"><text>活动总人数</text></view>
      <input
        class="text-field"
        type="number"
        value="{{createForm.totalCapacity}}"
        placeholder="例如：36"
        data-field="totalCapacity"
        bindinput="handleCreateInput"
      />
      <view class="form-help"><text>用户先报名，组织者后续线下统一分配，系统内不落到具体场地。</text></view>
    </view>

    <view
      wx:if="{{createForm.signupMode === 'USER_SELECT_COURT'}}"
      class="form-section"
    >
      <view class="form-label"><text>启用场地</text></view>
      <view class="form-help"><text>组织者先配置可报名场地，用户报名时自主选择对应场地。</text></view>

      <view class="court-list">
        <view
          wx:for="{{availableCourts}}"
          wx:key="venueCourtId"
          wx:for-item="court"
          class="court-card {{court.enabled ? 'court-card--active' : ''}}"
        >
          <view class="court-card__top">
            <view class="court-card__name"><text>{{court.label}}</text></view>
            <view
              class="court-card__toggle"
              data-court-index="{{index}}"
              bindtap="handleToggleCourt"
            ><text>{{court.enabled ? '已启用' : '点击启用'}}</text></view>
          </view>

          <view wx:if="{{court.enabled}}">
            <view class="form-section">
              <view class="form-label"><text>人数上限</text></view>
              <input
                class="text-field"
                type="number"
                value="{{court.capacity}}"
                data-court-index="{{index}}"
                data-field="capacity"
                bindinput="handleCourtInput"
              />
            </view>
          </view>
        </view>
      </view>
    </view>
  </view>

  <view class="section-card">
    <view class="section-header">
      <view class="section-title"><text>活动图文详情</text></view>
      <view class="editor-toolbar">
        <view
          class="section-link"
          bindtap="handleAddParagraphBlock"
        ><text>新增文字</text></view>
        <view
          class="section-link"
          bindtap="handleAddImageBlock"
        ><text>插入图片</text></view>
      </view>
    </view>

    <view class="form-help"><text>支持文字段落与图片混排，可为空；当前版本不支持视频、外链、表格和复杂排版。</text></view>

    <view class="description-editor">
      <view
        wx:for="{{descriptionBlocks}}"
        wx:key="id"
        wx:for-item="block"
        class="description-block"
      >
        <view class="description-block__header">
          <view class="description-block__label"><text>{{block.type === 'paragraph' ? '文字段落' : '图片内容'}}</text></view>
          <view class="description-block__actions">
            <view
              class="block-action {{index === 0 ? 'block-action--disabled' : ''}}"
              data-block-index="{{index}}"
              data-delta="-1"
              bindtap="handleMoveDescriptionBlock"
            ><text>上移</text></view>
            <view
              class="block-action {{index === descriptionBlocks.length - 1 ? 'block-action--disabled' : ''}}"
              data-block-index="{{index}}"
              data-delta="1"
              bindtap="handleMoveDescriptionBlock"
            ><text>下移</text></view>
            <view
              class="block-action block-action--danger"
              data-block-index="{{index}}"
              bindtap="handleDeleteDescriptionBlock"
            ><text>删除</text></view>
          </view>
        </view>

        <textarea
          wx:if="{{block.type === 'paragraph'}}"
          class="textarea-field textarea-field--block"
          value="{{block.text}}"
          placeholder="填写玩法、水平要求、报名说明等"
          data-block-index="{{index}}"
          bindinput="handleDescriptionBlockInput"
        ></textarea>

        <view
          wx:if="{{block.type === 'image'}}"
          class="image-block"
        >
          <image
            class="image-block__preview"
            src="{{block.src}}"
            mode="aspectFill"
          />
          <view class="image-block__footer">
            <view class="form-help"><text>图片将按当前顺序展示在活动详情中。</text></view>
            <view
              class="section-link"
              data-block-index="{{index}}"
              bindtap="handleReplaceImageBlock"
            ><text>更换图片</text></view>
          </view>
        </view>
      </view>
    </view>
    </view>

    <view class="page-actions">
      <view
        class="action-button action-button--secondary"
        bindtap="handleBack"
      ><text>返回</text></view>
      <view
        class="action-button action-button--primary"
        bindtap="handleSubmitCreate"
      ><text>发布活动</text></view>
    </view>
</view>

<view
  wx:if="{{showVenueManager}}"
  class="sheet-mask"
  bindtap="handleCloseVenueManager"
></view>
<view
  wx:if="{{showVenueManager}}"
  class="venue-sheet"
  catchtap="handleVenueSheetTap"
>
  <view class="venue-sheet__handle">
    <view class="venue-sheet__handle-bar"></view>
  </view>

  <view class="venue-sheet__header">
    <view class="venue-sheet__title"><text>场馆与场地管理</text></view>
    <view class="venue-sheet__subtitle"><text>保存后会回到当前表单，并刷新可选场馆与场地。</text></view>
  </view>

  <scroll-view
    class="venue-sheet__body"
    scroll-y="true"
    show-scrollbar="{{false}}"
  >
    <view class="venue-sheet__section">
      <view class="form-section">
        <view class="section-header">
          <view class="form-label"><text>管理场馆</text></view>
          <view
            class="section-link"
            bindtap="handleStartCreateVenue"
          ><text>新建场馆</text></view>
        </view>

        <picker
          wx:if="{{managerVenueLabels.length > 0}}"
          mode="selector"
          range="{{managerVenueLabels}}"
          value="{{selectedManagerVenueIndex}}"
          bindchange="handleManagerVenueChange"
        >
          <view class="picker-field"><text>{{venueManagerForm.isNew ? '新建场馆中' : managerVenueLabels[selectedManagerVenueIndex]}}</text></view>
        </picker>
      </view>
    </view>

    <view class="venue-sheet__section">
      <view class="form-grid">
        <view class="form-grid__item">
          <view class="form-label"><text>场馆名称</text></view>
          <input
            class="text-field"
            value="{{venueManagerForm.name}}"
            placeholder="例如：浦东金桥羽毛球馆"
            data-field="name"
            bindinput="handleVenueManagerInput"
          />
        </view>

        <view class="form-grid__item">
          <view class="form-label"><text>简称</text></view>
          <input
            class="text-field"
            value="{{venueManagerForm.shortName}}"
            placeholder="例如：金桥馆"
            data-field="shortName"
            bindinput="handleVenueManagerInput"
          />
        </view>
      </view>
    </view>

    <view class="venue-sheet__section">
      <view class="form-grid">
        <view class="form-grid__item">
          <view class="form-label"><text>省份</text></view>
          <input
            class="text-field"
            value="{{venueManagerForm.province}}"
            placeholder="可选手填"
            data-field="province"
            bindinput="handleVenueManagerInput"
          />
        </view>

        <view class="form-grid__item">
          <view class="form-label"><text>城市</text></view>
          <input
            class="text-field"
            value="{{venueManagerForm.city}}"
            placeholder="可选手填"
            data-field="city"
            bindinput="handleVenueManagerInput"
          />
        </view>
      </view>
    </view>

    <view class="venue-sheet__section">
      <view class="form-grid">
        <view class="form-grid__item">
          <view class="form-label"><text>区域</text></view>
          <input
            class="text-field"
            value="{{venueManagerForm.district}}"
            placeholder="例如：浦东新区"
            data-field="district"
            bindinput="handleVenueManagerInput"
          />
        </view>

        <view class="form-grid__item">
          <view class="form-label"><text>导航名</text></view>
          <input
            class="text-field"
            value="{{venueManagerForm.navigationName}}"
            placeholder="默认同场馆名称"
            data-field="navigationName"
            bindinput="handleVenueManagerInput"
          />
        </view>
      </view>
    </view>

    <view class="venue-sheet__section">
      <view class="form-section">
        <view class="section-header">
          <view class="form-label"><text>地图定位</text></view>
          <view
            class="section-link"
            bindtap="handleChooseVenueLocation"
          ><text>地图选点</text></view>
        </view>
        <view class="form-help"><text>回填地点名、详细地址、经纬度；省市区可继续手动修正。</text></view>
        <view class="location-card">
          <view class="location-card__row">
            <view class="location-card__label"><text>地点名</text></view>
            <view class="location-card__value"><text>{{venueManagerForm.locationName || '未选择'}}</text></view>
          </view>
          <view class="location-card__row">
            <view class="location-card__label"><text>经纬度</text></view>
            <view class="location-card__value"><text>{{venueManagerForm.latitude || '-'}} / {{venueManagerForm.longitude || '-'}}</text></view>
          </view>
        </view>
      </view>

      <view class="form-section">
        <view class="form-label"><text>详细地址</text></view>
        <input
          class="text-field"
          value="{{venueManagerForm.address}}"
          placeholder="详细地址"
          data-field="address"
          bindinput="handleVenueManagerInput"
        />
      </view>
    </view>

    <view class="venue-sheet__section">
      <view class="form-section">
        <view class="section-header">
          <view class="form-label"><text>场地列表</text></view>
          <view
            class="section-link"
            bindtap="handleAddManagerCourt"
          ><text>新增场地</text></view>
        </view>
        <view class="form-help"><text>停用后的场地不会影响历史活动快照，但不会再出现在新建活动里。</text></view>

        <view class="manager-court-list">
          <view
            wx:for="{{managerCourts}}"
            wx:key="rowKey"
            wx:for-item="court"
            class="manager-court-card {{court.status === 'INACTIVE' ? 'manager-court-card--inactive' : ''}}"
          >
            <view class="section-header">
              <view class="court-card__name"><text>{{court.courtName || court.courtCode || '新场地'}}</text></view>
              <view class="manager-court__tag"><text>{{court.status === 'ACTIVE' ? '启用中' : '已停用'}}</text></view>
            </view>

            <view class="form-grid">
              <view class="form-grid__item">
                <view class="form-label"><text>场地号</text></view>
                <input
                  class="text-field"
                  value="{{court.courtCode}}"
                  placeholder="例如：1 / A"
                  data-court-index="{{index}}"
                  data-field="courtCode"
                  bindinput="handleManagerCourtInput"
                  disabled="{{court.status !== 'ACTIVE'}}"
                />
              </view>

              <view class="form-grid__item">
                <view class="form-label"><text>场地名称</text></view>
                <input
                  class="text-field"
                  value="{{court.courtName}}"
                  placeholder="例如：1 号场"
                  data-court-index="{{index}}"
                  data-field="courtName"
                  bindinput="handleManagerCourtInput"
                  disabled="{{court.status !== 'ACTIVE'}}"
                />
              </view>
            </view>

            <view class="manager-court__footer">
              <view
                class="section-link {{court.status !== 'ACTIVE' && !court.isNew ? 'section-link--muted' : ''}}"
                data-court-index="{{index}}"
                bindtap="handleToggleManagerCourtStatus"
              ><text>{{court.isNew ? '移除' : court.status === 'ACTIVE' ? '停用场地' : '已停用'}}</text></view>
            </view>
          </view>
        </view>
      </view>
    </view>
  </scroll-view>

  <view class="venue-sheet__footer">
    <view
      class="action-button action-button--secondary"
      bindtap="handleCloseVenueManager"
    ><text>取消</text></view>
    <view
      class="action-button action-button--primary"
      bindtap="handleSaveVenueManager"
    ><text>保存配置</text></view>
  </view>
</view>
