page {
  background: #f7f7f7;
}

.create-page {
  min-height: 100vh;
  padding: 24rpx 24rpx calc(48rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  background: #f7f7f7;
}

.create-page__hero {
  padding: 24rpx;
  border-radius: 24rpx;
  background: #ffffff;
}

.create-page__eyebrow {
  color: #6b7280;
  font-size: 22rpx;
}

.create-page__title {
  margin-top: 12rpx;
  color: #111827;
  font-size: 40rpx;
  font-weight: 700;
}

.create-page__subtitle {
  margin-top: 8rpx;
  color: #6b7280;
  font-size: 24rpx;
  line-height: 1.6;
}

.notice-card,
.section-card {
  margin-top: 24rpx;
  padding: 24rpx;
  border-radius: 24rpx;
  background: #ffffff;
}

.notice-card {
  color: #92400e;
  background: #fffbeb;
  font-size: 24rpx;
  line-height: 1.6;
}

.section-header,
.court-card__top,
.court-card__switch-row,
.page-actions,
.manager-court__footer {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.section-title {
  color: #111827;
  font-size: 30rpx;
  font-weight: 700;
}

.section-link {
  color: #2563eb;
  font-size: 24rpx;
}

.editor-toolbar,
.description-block__header,
.description-block__actions,
.image-block__footer,
.location-card__row {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.owner-card__top {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.section-link--muted {
  color: #9ca3af;
}

.form-section {
  margin-top: 20rpx;
}

.form-label {
  color: #4b5563;
  font-size: 24rpx;
  font-weight: 600;
}

.form-help {
  margin-top: 8rpx;
  color: #9ca3af;
  font-size: 22rpx;
  line-height: 1.6;
}

.form-grid {
  display: flex;
  flex-direction: row;
  gap: 16rpx;
  margin-top: 20rpx;
}

.form-grid__item {
  flex: 1;
  min-width: 0;
}

.owner-card-list,
.mode-card-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-top: 12rpx;
}

.picker-field,
.text-field,
.textarea-field {
  width: 100%;
  margin-top: 12rpx;
  padding: 0 24rpx;
  border: 1px solid #e5e7eb;
  border-radius: 16rpx;
  box-sizing: border-box;
  background: #ffffff;
  color: #111827;
  font-size: 26rpx;
}

.picker-field,
.text-field {
  height: 84rpx;
  line-height: 84rpx;
}

.textarea-field {
  height: 220rpx;
  padding-top: 20rpx;
  padding-bottom: 20rpx;
  line-height: 1.6;
}

.textarea-field--block {
  height: 180rpx;
}

.court-list,
.manager-court-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-top: 20rpx;
}

.court-card,
.manager-court-card {
  padding: 20rpx;
  border: 1px solid #e5e7eb;
  border-radius: 20rpx;
  background: #f9fafb;
}

.owner-card,
.mode-card {
  padding: 20rpx;
  border: 1px solid #e5e7eb;
  border-radius: 20rpx;
  background: #f9fafb;
}

.owner-card--active,
.mode-card--active {
  border-color: #93c5fd;
  background: #eff6ff;
}

.owner-card__tag,
.owner-card__selected {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 40rpx;
  padding: 0 14rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
}

.owner-card__tag {
  color: #1d4ed8;
  background: #dbeafe;
}

.owner-card__selected {
  color: #047857;
  background: #d1fae5;
}

.owner-card__title,
.mode-card__title {
  margin-top: 16rpx;
  color: #111827;
  font-size: 28rpx;
  font-weight: 700;
}

.owner-card__meta,
.mode-card__meta {
  margin-top: 8rpx;
  color: #6b7280;
  font-size: 22rpx;
  line-height: 1.6;
}

.description-editor {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-top: 20rpx;
}

.description-block,
.location-card {
  padding: 20rpx;
  border: 1px solid #e5e7eb;
  border-radius: 20rpx;
  background: #f9fafb;
}

.description-block__label {
  color: #111827;
  font-size: 26rpx;
  font-weight: 700;
}

.block-action {
  color: #2563eb;
  font-size: 22rpx;
}

.block-action--disabled {
  color: #9ca3af;
}

.block-action--danger {
  color: #dc2626;
}

.image-block {
  margin-top: 12rpx;
}

.image-block__preview {
  width: 100%;
  height: 240rpx;
  border-radius: 16rpx;
  background: #e5e7eb;
}

.image-block__footer {
  margin-top: 16rpx;
}

.location-card {
  margin-top: 12rpx;
}

.location-card__row + .location-card__row {
  margin-top: 12rpx;
}

.location-card__label {
  color: #6b7280;
  font-size: 22rpx;
}

.location-card__value {
  max-width: 70%;
  color: #111827;
  font-size: 22rpx;
  line-height: 1.6;
  text-align: right;
}

.court-card--active {
  border-color: #93c5fd;
  background: #eff6ff;
}

.manager-court-card--inactive {
  opacity: 0.72;
  background: #f3f4f6;
}

.court-card__name {
  color: #111827;
  font-size: 28rpx;
  font-weight: 700;
}

.court-card__toggle,
.manager-court__tag {
  color: #2563eb;
  font-size: 24rpx;
}

.court-card__switch-row {
  margin-top: 20rpx;
}

.page-actions {
  margin-top: 32rpx;
}

.action-button {
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 1;
  height: 88rpx;
  border-radius: 999rpx;
  font-size: 28rpx;
  font-weight: 700;
}

.action-button--primary {
  color: #ffffff;
  background: #2563eb;
}

.action-button--secondary {
  color: #374151;
  background: #e5e7eb;
}

.sheet-mask {
  position: fixed;
  inset: 0;
  z-index: 40;
  background: rgba(17, 24, 39, 0.3);
  animation: sheet-mask-fade-in 180ms ease-out;
}

.venue-sheet {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 50;
  display: flex;
  flex-direction: column;
  height: 82vh;
  max-height: calc(100vh - 48rpx);
  min-height: 760rpx;
  overflow: hidden;
  background: #ffffff;
  border-radius: 32rpx 32rpx 0 0;
  box-shadow: 0 -12rpx 48rpx rgba(17, 24, 39, 0.16);
  animation: venue-sheet-slide-up 220ms ease-out;
}

.venue-sheet__handle {
  display: flex;
  justify-content: center;
  padding: 16rpx 0 8rpx;
  flex-shrink: 0;
}

.venue-sheet__handle-bar {
  width: 88rpx;
  height: 8rpx;
  border-radius: 999rpx;
  background: #d1d5db;
}

.venue-sheet__header {
  padding: 0 24rpx 20rpx;
  flex-shrink: 0;
}

.venue-sheet__title {
  color: #111827;
  font-size: 32rpx;
  font-weight: 700;
}

.venue-sheet__subtitle {
  margin-top: 8rpx;
  color: #6b7280;
  font-size: 24rpx;
  line-height: 1.6;
}

.venue-sheet__body {
  flex: 1;
  min-height: 0;
  height: 100%;
}

.venue-sheet__section {
  padding: 0 24rpx;
}

.venue-sheet__section + .venue-sheet__section {
  margin-top: 20rpx;
}

.venue-sheet__footer {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 16rpx;
  padding: 24rpx 24rpx calc(24rpx + env(safe-area-inset-bottom));
  border-top: 1px solid #e5e7eb;
  background: #ffffff;
  flex-shrink: 0;
}

@keyframes sheet-mask-fade-in {
  from {
    opacity: 0;
  }

  to {
    opacity: 1;
  }
}

@keyframes venue-sheet-slide-up {
  from {
    opacity: 0;
    transform: translateY(48rpx);
  }

  to {
    opacity: 1;
    transform: translateY(0);
  }
}
