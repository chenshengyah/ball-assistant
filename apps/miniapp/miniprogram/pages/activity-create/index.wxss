@import "../../styles/theme.wxss";

page {
  background: var(--iz-surface);
}

.create-page {
  min-height: 100vh;
  padding: 24rpx 24rpx calc(48rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  background:
    radial-gradient(circle at top right, rgba(112, 127, 228, 0.12), transparent 24%),
    var(--iz-surface);
}

.create-page__hero {
  padding: 24rpx;
  border-radius: 24rpx;
  background: var(--iz-surface-lowest);
  border: 1rpx solid var(--iz-outline);
  box-shadow: 0 20rpx 48rpx var(--iz-shadow-soft);
}

.create-page__eyebrow {
  color: var(--iz-text-secondary);
  font-size: 22rpx;
}

.create-page__title {
  margin-top: 12rpx;
  color: var(--iz-text-primary);
  font-size: 40rpx;
  font-weight: 700;
}

.create-page__subtitle {
  margin-top: 8rpx;
  color: var(--iz-text-secondary);
  font-size: 24rpx;
  line-height: 1.6;
}

.notice-card,
.section-card {
  margin-top: 24rpx;
  padding: 24rpx;
  border-radius: 24rpx;
  background: var(--iz-surface-lowest);
  border: 1rpx solid var(--iz-outline);
  box-shadow: 0 20rpx 48rpx var(--iz-shadow-soft);
}

.notice-card {
  color: var(--iz-color-tertiary);
  background: rgba(146, 56, 128, 0.08);
  font-size: 24rpx;
  line-height: 1.6;
}

.section-header,
.court-card__top,
.court-card__switch-row,
.page-actions,
.manager-court__footer {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.section-title {
  color: var(--iz-text-primary);
  font-size: 30rpx;
  font-weight: 700;
}

.section-link {
  color: var(--iz-color-primary);
  font-size: 24rpx;
}

.editor-toolbar,
.description-block__header,
.description-block__actions,
.image-block__footer,
.location-card__row {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.owner-card__top {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.section-link--muted {
  color: var(--iz-text-tertiary);
}

.section-link--danger {
  color: var(--iz-color-danger);
}

.form-section {
  margin-top: 20rpx;
}

.form-label {
  color: var(--iz-text-primary);
  font-size: 24rpx;
  font-weight: 600;
}

.form-help {
  margin-top: 8rpx;
  color: var(--iz-text-tertiary);
  font-size: 22rpx;
  line-height: 1.6;
}

.form-grid {
  display: flex;
  flex-direction: row;
  gap: 16rpx;
  margin-top: 20rpx;
}

.form-grid__item {
  flex: 1;
  min-width: 0;
}

.owner-card-list,
.mode-card-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-top: 12rpx;
}

.picker-field,
.text-field,
.textarea-field {
  width: 100%;
  margin-top: 12rpx;
  padding: 0 24rpx;
  border: 1px solid var(--iz-outline);
  border-radius: 16rpx;
  box-sizing: border-box;
  background: var(--iz-surface-lowest);
  color: var(--iz-text-primary);
  font-size: 26rpx;
}

.picker-field,
.text-field {
  height: 84rpx;
  line-height: 84rpx;
}

.picker-field {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-right: 56rpx;
}

.picker-field::after {
  content: "";
  position: absolute;
  right: 26rpx;
  top: 50%;
  width: 14rpx;
  height: 14rpx;
  border-right: 3rpx solid var(--iz-text-tertiary);
  border-bottom: 3rpx solid var(--iz-text-tertiary);
  transform: translateY(-62%) rotate(45deg);
}

.textarea-field {
  height: 220rpx;
  padding-top: 20rpx;
  padding-bottom: 20rpx;
  line-height: 1.6;
}

.textarea-field--block {
  height: 180rpx;
}

.court-list,
.manager-court-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-top: 20rpx;
}

.court-card,
.manager-court-card {
  padding: 20rpx;
  border: 1px solid var(--iz-outline);
  border-radius: 20rpx;
  background: var(--iz-surface-low);
}

.owner-card,
.mode-card {
  padding: 20rpx;
  border: 1px solid var(--iz-outline);
  border-radius: 20rpx;
  background: var(--iz-surface-low);
}

.owner-card--active,
.mode-card--active {
  border-color: var(--iz-outline-focus);
  background: var(--iz-color-primary-soft);
}

.owner-card__tag,
.owner-card__selected {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 40rpx;
  padding: 0 14rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
}

.owner-card__tag {
  color: var(--iz-color-primary);
  background: var(--iz-surface-high);
}

.owner-card__selected {
  color: var(--iz-color-success);
  background: rgba(30, 130, 76, 0.12);
}

.owner-card__title,
.mode-card__title {
  margin-top: 16rpx;
  color: var(--iz-text-primary);
  font-size: 28rpx;
  font-weight: 700;
}

.owner-card__meta,
.mode-card__meta {
  margin-top: 8rpx;
  color: var(--iz-text-secondary);
  font-size: 22rpx;
  line-height: 1.6;
}

.owner-card__status {
  margin-top: 12rpx;
  color: var(--iz-color-primary);
  font-size: 22rpx;
  font-weight: 600;
}

.cover-uploader {
  margin-top: 12rpx;
  min-height: 220rpx;
  border-radius: 20rpx;
  overflow: hidden;
  background: var(--iz-surface-low);
  border: 1px dashed var(--iz-outline-strong);
}

.cover-uploader--logo {
  min-height: 180rpx;
}

.cover-uploader__image {
  width: 100%;
  height: 220rpx;
}

.cover-uploader--logo .cover-uploader__image {
  height: 180rpx;
}

.cover-uploader__placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 84rpx;
  margin-top: 12rpx;
  padding: 0 24rpx;
  border: 1px solid var(--iz-outline);
  border-radius: 16rpx;
  box-sizing: border-box;
  background: var(--iz-surface-low);
  color: var(--iz-text-secondary);
  font-size: 24rpx;
  text-align: center;
}

.cover-uploader__placeholder {
  min-height: 220rpx;
}

.description-editor {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-top: 20rpx;
}

.description-block,
.empty-field,
.location-card {
  padding: 20rpx;
  border: 1px solid var(--iz-outline);
  border-radius: 20rpx;
  background: var(--iz-surface-low);
}

.empty-field {
  margin-top: 12rpx;
}

.empty-field__title {
  color: var(--iz-text-primary);
  font-size: 26rpx;
  font-weight: 700;
}

.empty-field__meta {
  margin-top: 8rpx;
  color: var(--iz-text-secondary);
  font-size: 22rpx;
  line-height: 1.6;
}

.empty-field__action {
  margin-top: 16rpx;
  color: var(--iz-color-primary);
  font-size: 24rpx;
  font-weight: 700;
}

.description-block__label {
  color: var(--iz-text-primary);
  font-size: 26rpx;
  font-weight: 700;
}

.block-action {
  color: var(--iz-color-primary);
  font-size: 22rpx;
}

.block-action--disabled {
  color: var(--iz-text-tertiary);
}

.block-action--danger {
  color: var(--iz-color-danger);
}

.image-block {
  margin-top: 12rpx;
}

.image-block__preview {
  width: 100%;
  height: 240rpx;
  border-radius: 16rpx;
  background: var(--iz-surface-high);
}

.image-block__footer {
  margin-top: 16rpx;
}

.location-card {
  margin-top: 12rpx;
}

.location-card__row + .location-card__row {
  margin-top: 12rpx;
}

.location-card__label {
  color: var(--iz-text-secondary);
  font-size: 22rpx;
}

.location-card__value {
  max-width: 70%;
  color: var(--iz-text-primary);
  font-size: 22rpx;
  line-height: 1.6;
  text-align: right;
}

.court-card--active {
  border-color: var(--iz-outline-focus);
  background: var(--iz-color-primary-soft);
}

.court-card__name {
  color: var(--iz-text-primary);
  font-size: 28rpx;
  font-weight: 700;
}

.court-card__toggle {
  color: var(--iz-color-primary);
  font-size: 24rpx;
}

.court-card__switch-row {
  margin-top: 20rpx;
}

.page-actions {
  margin-top: 32rpx;
}

.action-button {
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 1;
  height: 88rpx;
  border-radius: 999rpx;
  font-size: 28rpx;
  font-weight: 700;
}

.action-button--primary {
  color: var(--iz-surface-on-primary);
  background: var(--iz-color-primary);
}

.action-button--secondary {
  color: var(--iz-text-primary);
  background: var(--iz-surface-high);
}

.sheet-mask {
  position: fixed;
  inset: 0;
  z-index: 40;
  background: rgba(44, 42, 81, 0.24);
  animation: sheet-mask-fade-in 180ms ease-out;
}

.venue-sheet {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 50;
  display: flex;
  flex-direction: column;
  height: 82vh;
  max-height: calc(100vh - 48rpx);
  min-height: 760rpx;
  overflow: hidden;
  background: var(--iz-surface-lowest);
  border-radius: 32rpx 32rpx 0 0;
  box-shadow: 0 -12rpx 48rpx var(--iz-shadow-medium);
  animation: venue-sheet-slide-up 220ms ease-out;
}

.venue-sheet__handle {
  display: flex;
  justify-content: center;
  padding: 16rpx 0 8rpx;
  flex-shrink: 0;
}

.venue-sheet__handle-bar {
  width: 88rpx;
  height: 8rpx;
  border-radius: 999rpx;
  background: var(--iz-outline-strong);
}

.venue-sheet__header {
  padding: 0 24rpx 20rpx;
  flex-shrink: 0;
}

.venue-sheet__title {
  color: var(--iz-text-primary);
  font-size: 32rpx;
  font-weight: 700;
}

.venue-sheet__subtitle {
  margin-top: 8rpx;
  color: var(--iz-text-secondary);
  font-size: 24rpx;
  line-height: 1.6;
}

.venue-sheet__body {
  flex: 1;
  min-height: 0;
  height: 100%;
}

.venue-sheet__section {
  padding: 0 24rpx;
}

.venue-sheet__section + .venue-sheet__section {
  margin-top: 20rpx;
}

.venue-sheet__footer {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 16rpx;
  padding: 24rpx 24rpx calc(24rpx + env(safe-area-inset-bottom));
  border-top: 1px solid var(--iz-outline);
  background: var(--iz-surface-lowest);
  flex-shrink: 0;
}

@keyframes sheet-mask-fade-in {
  from {
    opacity: 0;
  }

  to {
    opacity: 1;
  }
}

@keyframes venue-sheet-slide-up {
  from {
    opacity: 0;
    transform: translateY(48rpx);
  }

  to {
    opacity: 1;
    transform: translateY(0);
  }
}
