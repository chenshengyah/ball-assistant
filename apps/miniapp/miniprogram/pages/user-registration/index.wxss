@import "../../styles/theme.wxss";

page {
  background: var(--iz-surface);
}

.registration-page {
  min-height: 100vh;
  padding: 40rpx 32rpx;
  box-sizing: border-box;
  background:
    radial-gradient(circle at top right, rgba(112, 127, 228, 0.14), transparent 26%),
    var(--iz-surface);
}

.registration-hero__eyebrow {
  font-size: 24rpx;
  color: var(--iz-color-primary);
  font-weight: 700;
  letter-spacing: 0.08em;
}

.registration-hero__title {
  margin-top: 8rpx;
  font-size: 48rpx;
  font-weight: 700;
  color: var(--iz-text-primary);
}

.registration-hero__subtitle {
  margin-top: 12rpx;
  font-size: 26rpx;
  line-height: 1.7;
  color: var(--iz-text-secondary);
}

.registration-card {
  margin-top: 32rpx;
  padding: 32rpx;
  border-radius: 32rpx;
  background: var(--iz-surface-lowest);
  border: 1rpx solid var(--iz-outline);
  box-shadow: 0 20rpx 48rpx var(--iz-shadow-soft);
}

.registration-submit::after {
  border: 0;
}

.registration-card__hint {
  margin-top: 24rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: var(--iz-text-tertiary);
}

.registration-submit {
  margin-top: 28rpx;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  border-radius: 999rpx;
  background: var(--iz-color-primary);
  color: var(--iz-surface-on-primary);
  font-size: 28rpx;
  font-weight: 600;
  box-shadow: 0 16rpx 40rpx var(--iz-shadow-primary-soft);
}

.registration-submit--hover {
  opacity: 0.88;
}
