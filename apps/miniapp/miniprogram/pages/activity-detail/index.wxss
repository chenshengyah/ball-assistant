page {
  background: #f8fafc;
}

.detail-page,
.missing-page {
  min-height: 100vh;
  padding: 32rpx;
  box-sizing: border-box;
}

.detail-card,
.court-card,
.guest-tip,
.missing-page {
  border-radius: 28rpx;
  background: #ffffff;
  box-shadow: 0 20rpx 48rpx rgba(15, 23, 42, 0.06);
}

.detail-card,
.court-card {
  padding: 28rpx;
}

.detail-card__top,
.court-card__top,
.detail-meta__row,
.court-card__footer,
.detail-actions {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.detail-card__title {
  font-size: 40rpx;
  font-weight: 700;
  color: #0f172a;
}

.detail-card__owner {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #64748b;
}

.detail-card__status,
.summary-pill {
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: #dbeafe;
  font-size: 22rpx;
  color: #1d4ed8;
}

.detail-card__summary {
  margin-top: 20rpx;
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  gap: 12rpx;
}

.summary-pill--soft {
  background: #eff6ff;
}

.detail-meta {
  margin-top: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.detail-meta__label {
  font-size: 24rpx;
  color: #64748b;
}

.detail-meta__value {
  max-width: 70%;
  font-size: 24rpx;
  line-height: 1.6;
  color: #0f172a;
  text-align: right;
}

.detail-card__description {
  margin-top: 24rpx;
  font-size: 26rpx;
  line-height: 1.7;
  color: #334155;
}

.detail-card__description--empty {
  color: #64748b;
}

.detail-card__richtext {
  display: block;
  margin-top: 24rpx;
  font-size: 26rpx;
  line-height: 1.7;
  color: #334155;
}

.detail-card__richtext p {
  margin: 0 0 16rpx;
}

.detail-card__richtext image,
.detail-card__richtext img {
  width: 100%;
  margin: 0 0 16rpx;
  border-radius: 20rpx;
}

.court-list,
.detail-actions {
  margin-top: 24rpx;
}

.court-card + .court-card {
  margin-top: 20rpx;
}

.court-card__title {
  font-size: 30rpx;
  font-weight: 700;
  color: #0f172a;
}

.court-card__counts {
  font-size: 22rpx;
  color: #64748b;
}

.chip-list {
  margin-top: 20rpx;
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  gap: 12rpx;
}

.chip {
  display: inline-flex;
  flex-direction: row;
  align-items: center;
  gap: 10rpx;
  padding: 12rpx 18rpx;
  border-radius: 999rpx;
  background: #eff6ff;
  color: #1e293b;
  font-size: 22rpx;
}

.chip--mine {
  background: #dbeafe;
}

.chip__tag {
  color: #2563eb;
}

.court-card__footer {
  margin-top: 20rpx;
  flex-wrap: wrap;
}

.action-button {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 200rpx;
  height: 76rpx;
  padding: 0 24rpx;
  border-radius: 999rpx;
  font-size: 26rpx;
  font-weight: 600;
}

.action-button--primary {
  background: #0f172a;
  color: #ffffff;
}

.action-button--secondary {
  background: #eff6ff;
  color: #1d4ed8;
}

.action-button--danger {
  background: #fee2e2;
  color: #b91c1c;
}

.stepper {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.stepper__button {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background: #e2e8f0;
  color: #0f172a;
  font-size: 32rpx;
}

.stepper__button--disabled {
  opacity: 0.4;
}

.stepper__text {
  font-size: 24rpx;
  color: #475569;
}

.guest-tip {
  margin-top: 24rpx;
  padding: 24rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #475569;
}

.missing-page {
  padding: 48rpx 32rpx;
}

.missing-page__title {
  font-size: 40rpx;
  font-weight: 700;
  color: #0f172a;
}

.missing-page__text {
  margin-top: 12rpx;
  font-size: 26rpx;
  line-height: 1.7;
  color: #64748b;
}
