@import "../../styles/theme.wxss";

page {
  background: var(--iz-surface);
}

.detail-page,
.missing-page {
  min-height: 100vh;
  padding: 32rpx;
  box-sizing: border-box;
  background:
    radial-gradient(circle at top right, rgba(112, 127, 228, 0.14), transparent 24%),
    var(--iz-surface);
}

.detail-card,
.court-card,
.guest-tip,
.missing-page {
  border-radius: 28rpx;
  background: var(--iz-surface-lowest);
  border: 1rpx solid var(--iz-outline);
  box-shadow: 0 20rpx 48rpx var(--iz-shadow-soft);
}

.detail-card,
.court-card {
  padding: 28rpx;
}

.detail-card__top,
.court-card__top,
.detail-meta__row,
.court-card__footer,
.detail-actions {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.detail-card__title {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--iz-text-primary);
}

.detail-card__owner {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: var(--iz-text-secondary);
}

.detail-card__status,
.summary-pill {
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: var(--iz-surface-high);
  font-size: 22rpx;
  color: var(--iz-color-primary);
}

.detail-card__summary {
  margin-top: 20rpx;
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  gap: 12rpx;
}

.summary-pill--soft {
  background: var(--iz-color-primary-soft);
}

.detail-meta {
  margin-top: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.detail-meta__label {
  font-size: 24rpx;
  color: var(--iz-text-secondary);
}

.detail-meta__value {
  max-width: 70%;
  font-size: 24rpx;
  line-height: 1.6;
  color: var(--iz-text-primary);
  text-align: right;
}

.detail-card__description {
  margin-top: 24rpx;
  font-size: 26rpx;
  line-height: 1.7;
  color: var(--iz-text-primary);
}

.detail-card__description--empty {
  color: var(--iz-text-secondary);
}

.detail-card__richtext {
  display: block;
  margin-top: 24rpx;
  font-size: 26rpx;
  line-height: 1.7;
  color: var(--iz-text-primary);
}

.detail-card__richtext p {
  margin: 0 0 16rpx;
}

.detail-card__richtext image,
.detail-card__richtext img {
  width: 100%;
  margin: 0 0 16rpx;
  border-radius: 20rpx;
}

.court-list,
.detail-actions {
  margin-top: 24rpx;
}

.court-card + .court-card {
  margin-top: 20rpx;
}

.court-card__title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--iz-text-primary);
}

.court-card__counts {
  font-size: 22rpx;
  color: var(--iz-text-secondary);
}

.chip-list {
  margin-top: 20rpx;
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  gap: 12rpx;
}

.chip {
  display: inline-flex;
  flex-direction: row;
  align-items: center;
  gap: 10rpx;
  padding: 12rpx 18rpx;
  border-radius: 999rpx;
  background: var(--iz-color-primary-soft);
  color: var(--iz-text-primary);
  font-size: 22rpx;
}

.chip--mine {
  background: var(--iz-surface-high);
}

.chip__tag {
  color: var(--iz-color-primary);
}

.court-card__footer {
  margin-top: 20rpx;
  flex-wrap: wrap;
}

.action-button {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 200rpx;
  height: 76rpx;
  padding: 0 24rpx;
  border-radius: 999rpx;
  font-size: 26rpx;
  font-weight: 600;
}

.action-button--primary {
  background: var(--iz-color-primary);
  color: var(--iz-surface-on-primary);
}

.action-button--secondary {
  background: var(--iz-surface-high);
  color: var(--iz-color-primary);
}

.action-button--danger {
  background: rgba(190, 61, 91, 0.12);
  color: var(--iz-color-danger);
}

.stepper {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.stepper__button {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background: var(--iz-surface-high);
  color: var(--iz-text-primary);
  font-size: 32rpx;
}

.stepper__button--disabled {
  opacity: 0.4;
}

.stepper__text {
  font-size: 24rpx;
  color: var(--iz-text-secondary);
}

.guest-tip {
  margin-top: 24rpx;
  padding: 24rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: var(--iz-text-secondary);
}

.missing-page {
  padding: 48rpx 32rpx;
}

.missing-page__title {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--iz-text-primary);
}

.missing-page__text {
  margin-top: 12rpx;
  font-size: 26rpx;
  line-height: 1.7;
  color: var(--iz-text-secondary);
}
