<app-nav title="我的活动" fallbackUrl="/pages/profile/index"></app-nav>

<view class="my-activities-page" style="{{pageTopStyle}}">
  <view class="page-title"><text>我的活动</text></view>
  <view class="page-subtitle"><text>这里收口“我发布的”和“我报名的”活动，点进去统一进入活动详情。</text></view>

    <view
      wx:if="{{published.length > 0}}"
      class="section-card"
    >
      <view class="section-card__title"><text>我发布的</text></view>
      <view
        wx:for="{{published}}"
        wx:key="id"
        class="activity-row"
        data-activity-id="{{item.id}}"
        bindtap="handleOpenDetail"
      >
        <view>
          <view class="activity-row__title"><text>{{item.title}}</text></view>
          <view class="activity-row__meta"><text>{{item.ownerLabel}} · {{item.scheduleText}}</text></view>
        </view>
        <view class="activity-row__arrow"><text>›</text></view>
      </view>
    </view>

    <view
      wx:if="{{joined.length > 0}}"
      class="section-card"
    >
      <view class="section-card__title"><text>我报名的</text></view>
      <view
        wx:for="{{joined}}"
        wx:key="id"
        class="activity-row"
        data-activity-id="{{item.id}}"
        bindtap="handleOpenDetail"
      >
        <view>
          <view class="activity-row__title"><text>{{item.title}}</text></view>
          <view class="activity-row__meta"><text>{{item.signupLabel}} · {{item.scheduleText}}</text></view>
        </view>
        <view class="activity-row__arrow"><text>›</text></view>
      </view>
    </view>

    <view
      wx:if="{{published.length === 0 && joined.length === 0}}"
      class="empty-card"
    >
      <view class="empty-card__title"><text>还没有可回收的活动</text></view>
      <view class="empty-card__text"><text>后续你发布或报名的活动，会统一沉淀在这里。</text></view>
    </view>
</view>
