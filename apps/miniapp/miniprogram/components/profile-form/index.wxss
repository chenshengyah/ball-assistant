@import "../../styles/theme.wxss";

.profile-form__label {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
  color: var(--iz-text-primary);
}

.profile-form__label--top {
  margin-top: 24rpx;
}

.profile-form__input,
.profile-form__picker {
  margin-top: 12rpx;
  height: 88rpx;
  padding: 0 24rpx;
  border-radius: 24rpx;
  background: var(--iz-surface-low);
  border: 1rpx solid var(--iz-outline);
  font-size: 28rpx;
  line-height: 88rpx;
  color: var(--iz-text-primary);
  box-sizing: border-box;
}

.profile-form__picker {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-right: 56rpx;
}

.profile-form__picker::after {
  content: "";
  position: absolute;
  right: 26rpx;
  top: 50%;
  width: 14rpx;
  height: 14rpx;
  border-right: 3rpx solid var(--iz-text-tertiary);
  border-bottom: 3rpx solid var(--iz-text-tertiary);
  transform: translateY(-62%) rotate(45deg);
}

.profile-form__picker--placeholder {
  color: var(--iz-text-tertiary);
}

.profile-form__avatar {
  margin-top: 12rpx;
  padding: 18rpx 20rpx;
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 18rpx;
  border-radius: 24rpx;
  background: var(--iz-surface-low);
  border: 1rpx solid var(--iz-outline);
  color: var(--iz-text-primary);
  text-align: left;
  box-sizing: border-box;
}

.profile-form__avatar-preview {
  position: relative;
  flex: 0 0 auto;
}

.profile-form__avatar-image,
.profile-form__avatar-fallback {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
}

.profile-form__avatar-fallback {
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, var(--iz-color-primary), var(--iz-color-primary-strong));
  color: var(--iz-surface-on-primary);
  font-size: 34rpx;
  font-weight: 700;
}

.profile-form__avatar-copy {
  min-width: 0;
  flex: 1;
}

.profile-form__avatar-title {
  font-size: 28rpx;
  line-height: 1.4;
  font-weight: 700;
  color: var(--iz-text-primary);
}

.profile-form__avatar-subtitle {
  margin-top: 4rpx;
  font-size: 24rpx;
  line-height: 1.45;
  color: var(--iz-text-tertiary);
}

.profile-form__avatar-actions {
  display: flex;
  flex-direction: row;
  gap: 12rpx;
  margin-top: 12rpx;
}

.profile-form__avatar-action {
  margin: 0;
  padding: 0 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 54rpx;
  border-radius: 999rpx;
  background: var(--iz-color-primary);
  color: var(--iz-surface-on-primary);
  font-size: 23rpx;
  font-weight: 700;
  line-height: 54rpx;
}

.profile-form__avatar-action::after {
  border: 0;
}

.profile-form__avatar-action--hover {
  opacity: 0.86;
}

.profile-form__phone-card {
  margin-top: 12rpx;
  padding: 20rpx 24rpx;
  border-radius: 24rpx;
  background: var(--iz-surface-low);
  border: 1rpx solid var(--iz-outline);
}

.profile-form__phone-input {
  min-height: 56rpx;
  font-size: 26rpx;
  line-height: 1.6;
  color: var(--iz-text-primary);
}

.profile-form__phone-status {
  margin-top: 10rpx;
  color: var(--iz-text-tertiary);
  font-size: 26rpx;
  font-weight: 600;
}

.profile-form__summary {
  padding: 22rpx 24rpx;
  border-radius: 24rpx;
  background: var(--iz-surface-low);
  border: 1rpx solid var(--iz-outline);
  color: var(--iz-text-secondary);
  font-size: 26rpx;
  line-height: 1.6;
}
