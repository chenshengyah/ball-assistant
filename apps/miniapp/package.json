{
  "name": "@ball-assistant/miniapp",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev": "node -e \"console.log('Open apps/miniapp in WeChat DevTools')\"",
    "build": "node -e \"console.log('Build the miniapp with WeChat DevTools')\"",
    "lint": "eslint \"miniprogram/**/*.ts\"",
    "typecheck": "node -e \"console.log('Miniapp typecheck is temporarily tracked in WeChat DevTools until the local typings are upgraded')\"",
    "typecheck:strict": "tsc -p tsconfig.json --noEmit",
    "test": "node -e \"console.log('No miniapp automated tests yet')\"",
    "codegen:api": "openapi-typescript http://127.0.0.1:3000/api/openapi-json -o miniprogram/generated/api-types.d.ts"
  },
  "devDependencies": {
    "openapi-typescript": "^7.7.0"
  }
}
