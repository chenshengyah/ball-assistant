{
  "name": "@ball-assistant/miniapp",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev": "node -e \"console.log('Open apps/miniapp in WeChat DevTools')\"",
    "build": "node -e \"console.log('Build the miniapp with WeChat DevTools')\"",
    "lint": "eslint \"miniprogram/**/*.ts\"",
    "typecheck": "node -e \"console.log('Miniapp typecheck is temporarily tracked in WeChat DevTools until the local typings are upgraded')\"",
    "typecheck:strict": "tsc -p tsconfig.json --noEmit",
    "test": "node -e \"console.log('No miniapp automated tests yet')\"",
    "codegen:api": "node ./scripts/codegen-api.mjs",
    "env:generate": "node ./scripts/generate-miniapp-env.mjs",
    "ci:upload": "node ./scripts/upload-miniapp.mjs",
    "upload:dev": "MINIAPP_UPLOAD_TARGET=dev node ./scripts/upload-miniapp.mjs",
    "upload:experience": "MINIAPP_UPLOAD_TARGET=experience node ./scripts/upload-miniapp.mjs"
  },
  "devDependencies": {
    "@babel/core": "7.29.0",
    "@babel/helper-replace-supers": "7.28.6",
    "@babel/traverse": "7.29.0",
    "less": "4.1.3",
    "miniprogram-ci": "^1.9.11",
    "openapi-typescript": "^7.7.0"
  }
}
