page {
  background: #f9f5ff;
}

.home-page {
  min-height: 100vh;
  color: #2c2a51;
  background: #f9f5ff;
}

.home-topbar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 50;
  display: flex;
  align-items: center;
  padding-left: 16px;
  padding-right: 16px;
  box-sizing: border-box;
  background: rgba(249, 245, 255, 0.82);
  backdrop-filter: blur(18px);
}

.home-topbar__actions {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 12px;
}

.home-topbar__title {
  position: absolute;
  left: 50%;
  transform: translateX(-50%);
  font-size: 18px;
  font-weight: 700;
  letter-spacing: -0.02em;
}

.home-topbar__capsule-placeholder {
  display: flex;
  justify-content: flex-end;
  flex-shrink: 0;
}

.topbar-icon-button {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 24px;
  height: 24px;
  padding: 0;
  transition: opacity 0.2s ease;
}

.topbar-icon-button--hover {
  opacity: 0.8;
}

.icon-grid {
  display: grid;
  grid-template-columns: repeat(2, 7px);
  gap: 4px;
}

.icon-grid__dot {
  width: 7px;
  height: 7px;
  border-radius: 2px;
  background: #4052b6;
}

.icon-search {
  position: relative;
  width: 18px;
  height: 18px;
}

.icon-search__circle {
  width: 12px;
  height: 12px;
  border: 2px solid #595781;
  border-radius: 50%;
  box-sizing: border-box;
}

.icon-search__handle {
  position: absolute;
  right: 0;
  bottom: 1px;
  width: 8px;
  height: 2px;
  border-radius: 999px;
  background: #595781;
  transform: rotate(40deg);
  transform-origin: center;
}

.home-content {
  box-sizing: border-box;
}

.home-hero__title {
  font-size: 56px;
  line-height: 1.08;
  font-weight: 700;
  letter-spacing: -0.04em;
}

.home-hero__subtitle {
  margin-top: 6px;
  color: #595781;
  font-size: 14px;
  line-height: 1.5;
  font-weight: 500;
}

.home-search-block {
  margin-top: 16px;
}

.home-search {
  display: flex;
  align-items: center;
  gap: 8px;
}

.home-search__field {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 10px;
  height: 36px;
  padding: 0 16px;
  border-radius: 999px;
  background: rgba(221, 217, 255, 0.4);
  border: 1px solid rgba(172, 168, 215, 0.15);
  box-sizing: border-box;
}

.icon-search--field {
  width: 16px;
  height: 16px;
}

.icon-search--field .icon-search__circle,
.icon-search--field .icon-search__handle {
  background-color: #595781;
  border-color: #595781;
}

.home-search__input {
  flex: 1;
  min-width: 0;
  height: 100%;
  color: #2c2a51;
  font-size: 12px;
  font-weight: 500;
}

.home-search__placeholder {
  color: #595781;
  font-size: 12px;
  font-weight: 500;
}

.home-search__filter {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 36px;
  height: 36px;
  padding: 0;
  border-radius: 999px;
  background: #e3dfff;
  box-sizing: border-box;
  transition: opacity 0.2s ease;
}

.home-search__filter--hover {
  opacity: 0.9;
}

.icon-tune {
  position: relative;
  width: 18px;
  height: 18px;
}

.icon-tune__line {
  position: absolute;
  left: 0;
  width: 18px;
  height: 2px;
  border-radius: 999px;
  background: #4052b6;
}

.icon-tune__line--one {
  top: 3px;
}

.icon-tune__line--two {
  top: 8px;
}

.icon-tune__line--three {
  top: 13px;
}

.icon-tune__knob {
  position: absolute;
  width: 5px;
  height: 5px;
  border-radius: 50%;
  background: #4052b6;
}

.icon-tune__knob--one {
  top: 1px;
  left: 9px;
}

.icon-tune__knob--two {
  top: 6px;
  left: 3px;
}

.icon-tune__knob--three {
  top: 11px;
  left: 12px;
}

.category-strip {
  white-space: nowrap;
}

.category-strip__inner {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding-right: 24px;
}

.category-chip {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 32px;
  padding: 0 20px;
  border-radius: 999px;
  color: #595781;
  font-size: 12px;
  font-weight: 700;
  line-height: 1;
  background: #f3eeff;
  box-sizing: border-box;
  transition: opacity 0.2s ease;
}

.category-chip--active {
  color: #f3f1ff;
  background: #4052b6;
  box-shadow: 0 4px 10px rgba(64, 82, 182, 0.14);
}

.category-chip--hover {
  opacity: 0.88;
}

.activity-list {
  display: flex;
  flex-direction: column;
  gap: 16px;
  margin-top: 16px;
}

.activity-card {
  overflow: hidden;
  border-radius: 24px;
  background: #ffffff;
  border: 1px solid rgba(172, 168, 215, 0.1);
  box-shadow: 0 2px 10px rgba(44, 42, 81, 0.04);
}

.activity-card__cover {
  position: relative;
  height: 128px;
  overflow: hidden;
}

.activity-card__image {
  width: 100%;
  height: 100%;
}

.activity-card__price-badge {
  position: absolute;
  top: 8px;
  right: 8px;
  min-width: 56px;
  height: 24px;
  padding: 0 10px;
  border-radius: 999px;
  font-size: 10px;
  font-weight: 800;
  line-height: 24px;
  text-align: center;
  letter-spacing: 0.06em;
  box-sizing: border-box;
  background: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(8px);
}

.activity-card__price-badge--primary {
  color: #4052b6;
}

.activity-card__price-badge--success {
  color: #1e824c;
}

.activity-card__body {
  display: flex;
  flex-direction: column;
  gap: 12px;
  padding: 16px;
}

.activity-card__eyebrow {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  font-size: 9px;
  font-weight: 700;
  letter-spacing: 0.14em;
  text-transform: uppercase;
}

.activity-card__eyebrow--primary {
  color: #4052b6;
}

.activity-card__eyebrow--tertiary {
  color: #923880;
}

.activity-card__eyebrow-icon {
  width: 6px;
  height: 6px;
  border-radius: 50%;
  background: #4052b6;
}

.activity-card__eyebrow--tertiary .activity-card__eyebrow-icon {
  background: #923880;
}

.activity-card__title {
  margin-top: -4px;
  font-size: 18px;
  line-height: 1.3;
  font-weight: 700;
  letter-spacing: -0.03em;
}

.activity-card__meta {
  display: flex;
  flex-direction: column;
  gap: 6px;
  margin-top: -2px;
}

.activity-card__meta-item {
  display: flex;
  align-items: center;
  gap: 8px;
  color: #595781;
}

.activity-card__meta-text {
  font-size: 12px;
  font-weight: 600;
}

.meta-icon {
  width: 14px;
  height: 14px;
  border-radius: 50%;
  opacity: 0.7;
  background: #c9c4f2;
}

.meta-icon--schedule {
  background: #b5b0e5;
}

.activity-card__footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-top: 12px;
  border-top: 1px solid rgba(172, 168, 215, 0.1);
}

.activity-card__joined {
  display: flex;
  align-items: center;
  gap: 8px;
  min-width: 0;
}

.activity-card__avatars {
  display: flex;
  align-items: center;
}

.activity-card__avatar {
  width: 20px;
  height: 20px;
  margin-left: -6px;
  border: 1px solid #ffffff;
  border-radius: 50%;
  box-sizing: border-box;
}

.activity-card__avatar:first-child {
  margin-left: 0;
}

.activity-card__joined-text {
  color: #595781;
  font-size: 10px;
  font-weight: 700;
}

.activity-card__cta {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 28px;
  padding: 0 16px;
  border-radius: 999px;
  color: #f3f1ff;
  font-size: 10px;
  font-weight: 800;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  background: #4052b6;
  box-sizing: border-box;
  transition: opacity 0.2s ease;
}

.activity-card__cta--hover {
  opacity: 0.9;
}

.home-empty {
  margin-top: 16px;
  padding: 40px 24px;
  border-radius: 24px;
  background: rgba(255, 255, 255, 0.72);
  text-align: center;
}

.home-empty__number {
  color: #ddd9ff;
  font-size: 48px;
  line-height: 1;
  font-weight: 800;
}

.home-empty__title {
  margin-top: 16px;
  font-size: 16px;
  font-weight: 700;
}

.home-empty__subtitle {
  margin-top: 8px;
  color: #595781;
  font-size: 12px;
  line-height: 1.6;
}

.home-stats {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8px;
  padding: 40px 0;
}

.home-stats__number {
  color: #e3dfff;
  font-size: 48px;
  line-height: 1;
  font-weight: 800;
}

.home-stats__label {
  color: #595781;
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 0.2em;
}

.home-fab {
  position: fixed;
  z-index: 50;
  display: flex;
  align-items: center;
  gap: 8px;
  height: 48px;
  padding: 0 20px;
  border-radius: 999px;
  color: #f3f1ff;
  font-size: 14px;
  font-weight: 700;
  background: #4052b6;
  box-shadow: 0 12px 24px rgba(64, 82, 182, 0.22);
  box-sizing: border-box;
  transition: opacity 0.2s ease;
}

.home-fab--hover {
  opacity: 0.9;
}

.home-fab__plus {
  font-size: 18px;
  line-height: 1;
}
