    <scroll-view
      class="category-strip"
      style="{{categoryStripStyle}}"
      scroll-x
      enable-flex
      show-scrollbar="{{false}}"
    >
      <view class="category-strip__inner">
        <view
          wx:for="{{categories}}"
          wx:key="id"
          class="category-chip {{selectedCategory === item.id ? 'category-chip--active' : ''}}"
          data-category-id="{{item.id}}"
          hover-class="category-chip--hover"
          hover-stay-time="80"
          bindtap="handleCategoryTap"
        >{{item.label}}</view>
      </view>
    </scroll-view>

    <view
      wx:if="{{visibleActivities.length > 0}}"
      class="activity-list"
    >
      <view
        wx:for="{{visibleActivities}}"
        wx:key="id"
        class="activity-card"
      >
        <view class="activity-card__cover">
          <image
            class="activity-card__image"
            src="{{item.coverImageUrl}}"
            mode="aspectFill"
          />
          <view
            class="activity-card__price-badge activity-card__price-badge--{{item.priceTone}}"
          >{{item.priceText}}</view>
        </view>

        <view class="activity-card__body">
          <!-- <view class="activity-card__eyebrow activity-card__eyebrow--{{item.badgeTone}}">
            <view class="activity-card__eyebrow-icon"></view>
            <view>{{item.badge}}</view>
          </view>-->

          <view class="activity-card__title">{{item.title}}</view>

          <view class="activity-card__meta">
            <view class="activity-card__meta-item">
              <view class="meta-icon meta-icon--location"></view>
              <view class="activity-card__meta-text">{{item.location}}</view>
            </view>
            <view class="activity-card__meta-item">
              <view class="meta-icon meta-icon--schedule"></view>
              <view class="activity-card__meta-text">{{item.schedule}}</view>
            </view>
          </view>

          <view class="activity-card__footer">
            <view class="activity-card__joined">
              <view class="activity-card__avatars">
                <view
                  wx:for="{{item.avatars}}"
                  wx:key="*this"
                  wx:for-item="avatarColor"
                  class="activity-card__avatar"
                  style="background: {{avatarColor}};"
                ></view>
              </view>
              <view class="activity-card__joined-text">{{item.participants}}</view>
            </view>

            <view
              class="activity-card__cta"
              hover-class="activity-card__cta--hover"
              hover-stay-time="80"
              bindtap="handlePrimaryAction"
              data-title="{{item.title}}"
            >{{item.actionText}}</view>
          </view>
        </view>
      </view>
    </view>

    <view
      wx:else
      class="home-empty"
    >
      <view class="home-empty__number">0</view>
      <view class="home-empty__title">没有匹配的活动</view>
      <view class="home-empty__subtitle">试试切换分类或搜索别的关键词。</view>
    </view>

    <view class="home-stats">
      <view class="home-stats__number">12+</view>
      <view class="home-stats__label">EVENTS FOUND THIS WEEK</view>
    </view>
  </view>

  <view
    class="home-fab"
    style="{{fabStyle}}"
    hover-class="home-fab--hover"
    hover-stay-time="80"
    bindtap="handleCreateActivity"
  >
    <view class="home-fab__plus">+</view>
    <view>创建活动</view>
  </view>
</view>
