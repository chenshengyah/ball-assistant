  <view
    class="home-content"
    style="{{homeContentStyle}}"
  >
    <view class="home-hero">
      <view class="home-hero__title">发现好活动</view>
      <view class="home-hero__subtitle">看一看这周值得参加的活动吧！</view>
    </view>

