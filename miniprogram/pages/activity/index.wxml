<view class="activity-page">
  <view
    class="activity-header"
    style="{{headerStyle}}"
  >
    <view class="activity-header__title-wrap">
      <view class="activity-header__title">活动工作台</view>
      <view class="activity-header__subtitle">这里看活动列表、场馆主数据，并进入独立创建页</view>
    </view>
    <view
      class="activity-header__capsule"
      style="{{capsuleStyle}}"
    ></view>
  </view>

  <view
    class="activity-content"
    style="{{contentStyle}}"
  >
    <view class="activity-hero">
      <view class="activity-hero__profile">
        <view
          class="activity-hero__avatar"
          style="background: {{currentUserAvatarColor}};"
        >{{currentUserInitial}}</view>
        <view class="activity-hero__text">
          <view class="activity-hero__eyebrow">当前登录</view>
          <view class="activity-hero__name">{{currentUserName}}</view>
          <view class="activity-hero__roles">{{currentUserRoleSummary}}</view>
        </view>
      </view>

      <view class="activity-hero__stats">
        <view class="hero-stat">
          <view class="hero-stat__value">{{publishedCount}}</view>
          <view class="hero-stat__label">已发布活动</view>
        </view>
        <view class="hero-stat">
          <view class="hero-stat__value">{{manageableCount}}</view>
          <view class="hero-stat__label">可管理活动</view>
        </view>
        <view class="hero-stat">
          <view class="hero-stat__value">{{joinedCount}}</view>
          <view class="hero-stat__label">我的报名</view>
        </view>
      </view>

      <view class="activity-hero__actions">
        <view
          class="hero-button hero-button--primary"
          hover-class="hero-button--hover"
          hover-stay-time="80"
          bindtap="handleOpenCreate"
        >新建活动</view>
      </view>
    </view>

    <view class="segment-control">
      <view
        class="segment-control__item {{activeSegment === 'activities' ? 'segment-control__item--active' : ''}}"
        data-field="activities"
        bindtap="handleSegmentChange"
      >活动看板</view>
      <view
        class="segment-control__item {{activeSegment === 'venues' ? 'segment-control__item--active' : ''}}"
        data-field="venues"
        bindtap="handleSegmentChange"
      >场馆主数据</view>
    </view>

    <view wx:if="{{activeSegment === 'activities'}}">
      <view
        wx:if="{{activityCards.length > 0}}"
        class="activity-list"
      >
        <view
          wx:for="{{activityCards}}"
          wx:key="id"
          wx:for-item="activity"
          class="activity-card"
        >
          <view class="activity-card__top">
            <view>
              <view class="activity-card__title">{{activity.title}}</view>
              <view class="activity-card__owner">{{activity.ownerLabel}}</view>
            </view>
            <view class="activity-card__status">{{activity.statusLabel}}</view>
          </view>

          <view class="activity-card__summary">
            <view class="summary-pill">{{activity.chargeText}}</view>
            <view class="summary-pill summary-pill--soft">{{activity.signupStatusLabel}}</view>
            <view class="summary-pill summary-pill--soft">已确认 {{activity.confirmedCount}}</view>
            <view class="summary-pill summary-pill--soft">候补 {{activity.waitlistCount}}</view>
          </view>

          <view class="activity-meta">
            <view class="activity-meta__row">
              <view class="activity-meta__label">报名模式</view>
              <view class="activity-meta__value">{{activity.signupModeLabel}}</view>
            </view>
            <view class="activity-meta__row">
              <view class="activity-meta__label">场馆</view>
              <view class="activity-meta__value">{{activity.venueLabel}}</view>
            </view>
            <view class="activity-meta__row">
              <view class="activity-meta__label">时间</view>
              <view class="activity-meta__value">{{activity.scheduleText}}</view>
            </view>
            <view class="activity-meta__row">
              <view class="activity-meta__label">报名截止</view>
              <view class="activity-meta__value">{{activity.cancelDeadlineText}}</view>
            </view>
            <view class="activity-meta__row">
              <view class="activity-meta__label">我的状态</view>
              <view class="activity-meta__value">{{activity.currentUserSignupLabel}}</view>
            </view>
          </view>

          <view class="activity-card__description">{{activity.descriptionRichtext}}</view>

          <view
            wx:if="{{activity.signupMode === 'USER_SELECT_COURT'}}"
            class="court-list"
          >
            <view
              wx:for="{{activity.courts}}"
              wx:key="id"
              wx:for-item="court"
              class="court-card"
            >
              <view class="court-card__header">
                <view class="court-card__title">{{court.label}}</view>
                <view class="court-card__counts">
                  <view>{{court.occupancyText}}</view>
                  <view>{{court.waitlistText}}</view>
                </view>
              </view>

              <view class="registration-chips">
                <view
                  wx:for="{{court.registrations}}"
                  wx:key="registrationId"
                  wx:for-item="registration"
                  class="registration-chip {{registration.isCurrentUser ? 'registration-chip--mine' : ''}}"
                  data-activity-id="{{activity.id}}"
                  data-registration-id="{{registration.registrationId}}"
                  bindtap="handleMoveRegistration"
                >
                  <text>{{registration.nickname}}</text>
                  <text class="registration-chip__tag">{{registration.tagText}}</text>
                </view>
              </view>

              <view class="court-card__footer">
                <view
                  wx:if="{{!activity.currentUserRegistrationId && court.canSignup}}"
                  class="court-card__button"
                  hover-class="court-card__button--hover"
                  hover-stay-time="80"
                  data-activity-id="{{activity.id}}"
                  data-activity-court-id="{{court.id}}"
                  bindtap="handleSignUp"
                >{{court.signupButtonText}}</view>

                <view
                  wx:if="{{activity.canManage}}"
                  class="capacity-stepper"
                >
                  <view
                    class="capacity-stepper__button {{!court.canDecreaseCapacity ? 'capacity-stepper__button--disabled' : ''}}"
                    data-activity-id="{{activity.id}}"
                    data-activity-court-id="{{court.id}}"
                    data-delta="-1"
                    bindtap="handleAdjustCapacity"
                  >-</view>
                  <view class="capacity-stepper__value">调容量</view>
                  <view
                    class="capacity-stepper__button"
                    data-activity-id="{{activity.id}}"
                    data-activity-court-id="{{court.id}}"
                    data-delta="1"
                    bindtap="handleAdjustCapacity"
                  >+</view>
                </view>
              </view>
            </view>
          </view>

          <view
            wx:if="{{activity.signupMode === 'GENERAL'}}"
            class="court-list"
          >
            <view class="court-card">
              <view class="court-card__header">
                <view class="court-card__title">统一报名</view>
                <view class="court-card__counts">
                  <view>{{activity.totalCapacityText}}</view>
                  <view>{{activity.waitlistCount}} 候补</view>
                </view>
              </view>

              <view class="registration-chips">
                <view
                  wx:for="{{activity.registrations}}"
                  wx:key="registrationId"
                  wx:for-item="registration"
                  class="registration-chip {{registration.isCurrentUser ? 'registration-chip--mine' : ''}}"
                >
                  <text>{{registration.nickname}}</text>
                  <text class="registration-chip__tag">{{registration.tagText}}</text>
                </view>
              </view>

              <view class="court-card__footer">
                <view
                  wx:if="{{!activity.currentUserRegistrationId && activity.canGeneralSignUp}}"
                  class="court-card__button"
                  hover-class="court-card__button--hover"
                  hover-stay-time="80"
                  data-activity-id="{{activity.id}}"
                  bindtap="handleSignUp"
                >{{activity.generalSignupButtonText}}</view>
              </view>
            </view>
          </view>

          <view class="activity-card__footer">
            <view
              class="footer-button footer-button--secondary"
              hover-class="footer-button--hover"
              hover-stay-time="80"
              data-activity-id="{{activity.id}}"
              bindtap="handleRepublish"
            >再次发布</view>
            <view
              wx:if="{{activity.canCancelCurrentUserRegistration}}"
              class="footer-button footer-button--danger"
              hover-class="footer-button--hover"
              hover-stay-time="80"
              data-registration-id="{{activity.currentUserRegistrationId}}"
              bindtap="handleCancelRegistration"
            >取消我的报名</view>
          </view>
        </view>
      </view>

      <view
        wx:else
        class="empty-state"
      >
        <view class="empty-state__title">还没有活动</view>
        <view class="empty-state__text">先创建一场活动，再开放统一报名或按场地报名。</view>
      </view>
    </view>

    <view
      wx:if="{{activeSegment === 'venues'}}"
      class="venue-list"
    >
      <view
        wx:for="{{venues}}"
        wx:key="index"
        wx:for-item="venueItem"
        class="venue-card"
      >
        <view class="venue-card__top">
          <view>
            <view class="venue-card__title">{{venueItem.venue.name}}</view>
            <view
              class="venue-card__address"
            >{{venueItem.venue.district}} · {{venueItem.venue.address}}</view>
          </view>
          <view class="venue-card__tag">{{venueItem.courts.length}} 片场地</view>
        </view>

        <view class="venue-card__courts">
          <view
            wx:for="{{venueItem.courts}}"
            wx:key="id"
            wx:for-item="court"
            class="venue-court-chip"
          >{{court.courtName}}</view>
        </view>
      </view>
    </view>
  </view>
</view>
