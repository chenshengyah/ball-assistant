page {
  background:
    radial-gradient(circle at top left, rgba(255, 212, 173, 0.35), transparent 32%),
    linear-gradient(180deg, #fff8ed 0%, #f6efe6 100%);
}

.activity-page {
  min-height: 100vh;
  color: #2f241b;
  background:
    radial-gradient(circle at top left, rgba(255, 212, 173, 0.35), transparent 32%),
    linear-gradient(180deg, #fff8ed 0%, #f6efe6 100%);
}

.activity-header {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 40;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 20px;
  box-sizing: border-box;
  background: rgba(255, 248, 237, 0.8);
  backdrop-filter: blur(18px);
}

.activity-header__title-wrap {
  flex: 1;
  min-width: 0;
}

.activity-header__title {
  font-size: 20px;
  font-weight: 800;
  letter-spacing: -0.03em;
}

.activity-header__subtitle {
  margin-top: 4px;
  color: #7c6856;
  font-size: 11px;
  line-height: 1.5;
}

.activity-header__capsule {
  flex-shrink: 0;
}

.activity-content {
  box-sizing: border-box;
}

.activity-hero {
  padding: 22px;
  border-radius: 28px;
  background:
    linear-gradient(135deg, rgba(255, 255, 255, 0.98), rgba(255, 240, 224, 0.86)),
    #ffffff;
  box-shadow: 0 12px 36px rgba(140, 95, 40, 0.12);
}

.activity-hero__profile {
  display: flex;
  align-items: center;
  gap: 14px;
}

.activity-hero__avatar {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 52px;
  height: 52px;
  border-radius: 18px;
  color: #ffffff;
  font-size: 22px;
  font-weight: 800;
}

.activity-hero__text {
  min-width: 0;
}

.activity-hero__eyebrow {
  color: #8f7562;
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 0.16em;
  text-transform: uppercase;
}

.activity-hero__name {
  margin-top: 6px;
  font-size: 24px;
  font-weight: 800;
  letter-spacing: -0.03em;
}

.activity-hero__roles {
  margin-top: 6px;
  color: #6b5b4d;
  font-size: 12px;
  line-height: 1.6;
}

.activity-hero__stats {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 10px;
  margin-top: 18px;
}

.hero-stat {
  padding: 14px 12px;
  border-radius: 20px;
  background: rgba(255, 255, 255, 0.74);
}

.hero-stat__value {
  font-size: 22px;
  font-weight: 800;
}

.hero-stat__label {
  margin-top: 4px;
  color: #8f7562;
  font-size: 11px;
  line-height: 1.4;
}

.activity-hero__actions {
  display: flex;
  gap: 10px;
  margin-top: 18px;
}

.hero-button {
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 1;
  height: 44px;
  border-radius: 999px;
  font-size: 13px;
  font-weight: 700;
  transition: opacity 0.2s ease;
}

.hero-button--primary {
  color: #fffaf4;
  background: #d46d2c;
}

.hero-button--secondary {
  color: #7a5625;
  background: rgba(214, 152, 77, 0.14);
}

.hero-button--hover {
  opacity: 0.88;
}

.segment-control {
  display: inline-flex;
  gap: 8px;
  margin-top: 16px;
  padding: 6px;
  border-radius: 999px;
  background: rgba(255, 255, 255, 0.68);
}

.segment-control__item {
  display: flex;
  align-items: center;
  justify-content: center;
  min-width: 112px;
  height: 34px;
  padding: 0 18px;
  border-radius: 999px;
  color: #7d6c5d;
  font-size: 12px;
  font-weight: 700;
}

.segment-control__item--active {
  color: #fffaf4;
  background: #2f241b;
}

.activity-list,
.venue-list {
  display: flex;
  flex-direction: column;
  gap: 16px;
  margin-top: 18px;
}

.activity-card,
.venue-card {
  padding: 18px;
  border-radius: 28px;
  background: rgba(255, 255, 255, 0.9);
  box-shadow: 0 10px 30px rgba(111, 78, 38, 0.08);
}

.activity-card__top,
.venue-card__top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 12px;
}

.activity-card__title,
.venue-card__title {
  font-size: 20px;
  line-height: 1.25;
  font-weight: 800;
  letter-spacing: -0.03em;
}

.activity-card__owner,
.venue-card__address {
  margin-top: 6px;
  color: #7c6856;
  font-size: 12px;
  line-height: 1.5;
}

.activity-card__status,
.venue-card__tag {
  flex-shrink: 0;
  padding: 7px 12px;
  border-radius: 999px;
  color: #7a5625;
  font-size: 11px;
  font-weight: 700;
  background: rgba(214, 152, 77, 0.14);
}

.activity-card__summary {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  margin-top: 14px;
}

.summary-pill {
  padding: 7px 12px;
  border-radius: 999px;
  color: #fffaf4;
  font-size: 11px;
  font-weight: 700;
  background: #2f241b;
}

.summary-pill--soft {
  color: #7a5625;
  background: rgba(214, 152, 77, 0.12);
}

.activity-meta {
  display: flex;
  flex-direction: column;
  gap: 8px;
  margin-top: 16px;
}

.activity-meta__row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
}

.activity-meta__label {
  flex-shrink: 0;
  color: #987f68;
  font-size: 11px;
  font-weight: 700;
}

.activity-meta__value {
  text-align: right;
  font-size: 12px;
  line-height: 1.5;
}

.activity-card__description {
  margin-top: 16px;
  padding: 14px;
  border-radius: 18px;
  color: #69584a;
  font-size: 12px;
  line-height: 1.7;
  background: #f9f4ed;
}

.court-list {
  display: flex;
  flex-direction: column;
  gap: 12px;
  margin-top: 16px;
}

.court-card {
  padding: 14px;
  border-radius: 20px;
  background: #fbf7f2;
  border: 1px solid rgba(175, 136, 96, 0.12);
}

.court-card__header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 12px;
}

.court-card__title {
  font-size: 16px;
  font-weight: 800;
}

.court-card__counts {
  color: #846c57;
  font-size: 11px;
  line-height: 1.6;
  text-align: right;
}

.registration-chips,
.venue-card__courts {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  margin-top: 12px;
}

.registration-chip,
.venue-court-chip {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  padding: 8px 10px;
  border-radius: 999px;
  color: #5e4d3f;
  font-size: 11px;
  font-weight: 700;
  background: #ffffff;
}

.registration-chip--mine {
  color: #fffaf4;
  background: #2f241b;
}

.registration-chip__tag {
  opacity: 0.78;
}

.court-card__footer,
.activity-card__footer,
.sheet__footer,
.dialog__footer,
.form-row {
  display: flex;
  align-items: center;
  gap: 10px;
}

.court-card__footer {
  justify-content: space-between;
  margin-top: 14px;
}

.court-card__button,
.footer-button {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 96px;
  height: 36px;
  padding: 0 16px;
  border-radius: 999px;
  font-size: 12px;
  font-weight: 700;
}

.court-card__button {
  color: #fffaf4;
  background: #d46d2c;
}

.court-card__button--hover,
.footer-button--hover {
  opacity: 0.88;
}

.capacity-stepper {
  display: inline-flex;
  align-items: center;
  gap: 8px;
}

.capacity-stepper__button {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 28px;
  height: 28px;
  border-radius: 50%;
  color: #fffaf4;
  font-size: 16px;
  font-weight: 700;
  background: #2f241b;
}

.capacity-stepper__button--disabled {
  opacity: 0.35;
}

.capacity-stepper__value {
  color: #7c6856;
  font-size: 11px;
  font-weight: 700;
}

.activity-card__footer {
  margin-top: 16px;
}

.footer-button {
  flex: 1;
}

.footer-button--primary {
  color: #fffaf4;
  background: #d46d2c;
}

.footer-button--secondary {
  color: #6f5b46;
  background: #f5ede5;
}

.footer-button--danger {
  color: #fff4f2;
  background: #b85745;
}

.empty-state {
  margin-top: 18px;
  padding: 40px 24px;
  border-radius: 28px;
  text-align: center;
  background: rgba(255, 255, 255, 0.76);
}

.empty-state__title {
  font-size: 18px;
  font-weight: 800;
}

.empty-state__text {
  margin-top: 8px;
  color: #7c6856;
  font-size: 12px;
  line-height: 1.7;
}

.sheet-mask {
  position: fixed;
  inset: 0;
  z-index: 70;
  background: rgba(47, 36, 27, 0.32);
}

.sheet {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 80;
  height: 82vh;
  padding: 20px 20px calc(20px + env(safe-area-inset-bottom));
  border-radius: 32px 32px 0 0;
  background: #fff8f2;
  box-sizing: border-box;
}

.sheet__header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16px;
}

.sheet__title {
  font-size: 22px;
  font-weight: 800;
}

.sheet__subtitle {
  margin-top: 6px;
  color: #7c6856;
  font-size: 12px;
  line-height: 1.6;
}

.sheet__close {
  flex-shrink: 0;
  width: 32px;
  height: 32px;
  border-radius: 50%;
  color: #705e4c;
  font-size: 22px;
  line-height: 32px;
  text-align: center;
  background: #f5ede5;
}

.sheet__content {
  height: calc(100% - 108px);
  margin-top: 18px;
}

.form-section {
  margin-top: 16px;
}

.form-section:first-child {
  margin-top: 0;
}

.form-label {
  color: #7b6958;
  font-size: 12px;
  font-weight: 700;
}

.form-help {
  margin-top: 6px;
  color: #947f6a;
  font-size: 11px;
  line-height: 1.6;
}

.form-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 10px;
  margin-top: 12px;
}

.form-grid__item {
  min-width: 0;
}

.form-row {
  justify-content: space-between;
}

.form-row--between {
  margin-top: 12px;
}

.picker-field,
.text-field,
.textarea-field {
  width: 100%;
  margin-top: 10px;
  padding: 0 14px;
  border-radius: 16px;
  color: #2f241b;
  font-size: 13px;
  font-weight: 600;
  background: #ffffff;
  box-sizing: border-box;
}

.picker-field,
.text-field {
  height: 44px;
  line-height: 44px;
}

.textarea-field {
  height: 120px;
  padding-top: 12px;
  padding-bottom: 12px;
  line-height: 1.6;
}

.inline-link {
  color: #c06e2e;
  font-size: 12px;
  font-weight: 700;
}

.form-court-list {
  display: flex;
  flex-direction: column;
  gap: 12px;
  margin-top: 12px;
}

.form-court-card {
  padding: 14px;
  border-radius: 20px;
  border: 1px solid rgba(176, 141, 104, 0.12);
  background: #f7f1ea;
}

.form-court-card--active {
  border-color: rgba(212, 109, 44, 0.28);
  background: #fff9f3;
}

.form-court-card__top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
}

.form-court-card__name {
  font-size: 15px;
  font-weight: 800;
}

.form-court-card__toggle {
  color: #c06e2e;
  font-size: 12px;
  font-weight: 700;
}

.dialog {
  position: fixed;
  left: 20px;
  right: 20px;
  top: 50%;
  z-index: 90;
  padding: 20px;
  border-radius: 28px;
  background: #fff8f2;
  box-sizing: border-box;
  transform: translateY(-50%);
}

.dialog__title {
  font-size: 20px;
  font-weight: 800;
}

.dialog__subtitle {
  margin-top: 6px;
  margin-bottom: 12px;
  color: #7c6856;
  font-size: 12px;
  line-height: 1.6;
}

.dialog__footer {
  margin-top: 14px;
}
